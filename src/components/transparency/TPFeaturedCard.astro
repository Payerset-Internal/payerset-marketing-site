---
interface Props {
  tag: string;
  title: string;
  description: string;
  href: string;
  ctaLabel?: string;
}

const { tag, title, description, href, ctaLabel = 'Explore the scorecard' } = Astro.props;

const gradeColors: Record<string, string> = { a: '#6ee6a0', b: '#a8d8ea', c: '#ffd97d', d: '#ffb088', f: '#ff8888' };

const samplePayers = [
  { name: 'Aetna', grade: 'B+', score: 87, bar: 87 },
  { name: 'Blue Cross Blue Shield', grade: 'C', score: 72, bar: 72 },
  { name: 'Cigna', grade: 'B', score: 81, bar: 81 },
  { name: 'UnitedHealthcare', grade: 'C\u2212', score: 68, bar: 68 },
  { name: 'Humana', grade: 'D+', score: 54, bar: 54 },
].map(p => ({ ...p, color: gradeColors[p.grade.charAt(0).toLowerCase()] || '#fff' }));
---

<a class="group grid md:grid-cols-12 bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 no-underline text-inherit" href={href}>
  <!-- Visual -->
  <div class="md:col-span-5 bg-brand-dark-deep p-8 flex items-center justify-center min-h-[280px] relative overflow-hidden">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(255,255,255,0.04)_1px,transparent_1px),linear-gradient(90deg,rgba(255,255,255,0.04)_1px,transparent_1px)] bg-[size:32px_32px]"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_30%_60%,rgba(0,146,202,0.3)_0%,transparent_65%)]"></div>

    <div class="relative z-10 bg-white/8 border border-white/12 rounded-xl p-5 w-full max-w-xs backdrop-blur-sm">
      <div class="flex items-center gap-2 mb-4 pb-3 border-b border-white/10">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 3.5A1.5 1.5 0 013.5 2h9A1.5 1.5 0 0114 3.5v9a1.5 1.5 0 01-1.5 1.5h-9A1.5 1.5 0 012 12.5v-9z" stroke="rgba(255,255,255,0.6)" stroke-width="1.2"/><path d="M5 6h6M5 8.5h4M5 11h5" stroke="rgba(255,255,255,0.6)" stroke-width="1.2" stroke-linecap="round"/></svg>
        <span class="text-[0.7rem] font-semibold text-white/85 tracking-wide flex-1">Payer Compliance Scorecard</span>
        <span class="text-[0.55rem] font-semibold text-white/60 bg-white/10 px-2 py-0.5 rounded tracking-wider uppercase">Q1 2026</span>
      </div>
      <div class="flex flex-col gap-2.5">
        {samplePayers.map(payer => (
          <div class="grid grid-cols-[1fr_1.2fr_auto] items-center gap-2.5">
            <span class="text-[0.62rem] text-white/70 truncate">{payer.name}</span>
            <div class="h-1.5 bg-white/8 rounded-full overflow-hidden">
              <div class="h-full rounded-full bg-gradient-to-r from-white/30 to-white/55" style={`width:${payer.bar}%`}></div>
            </div>
            <span class="text-[0.65rem] font-bold w-7 text-center" style={`color:${payer.color}`}>{payer.grade}</span>
          </div>
        ))}
      </div>
      <div class="mt-3.5 pt-2.5 border-t border-white/10">
        <span class="text-[0.52rem] text-white/40 leading-relaxed">Grading 100+ payers across file completeness, accuracy & timeliness</span>
      </div>
    </div>
  </div>

  <!-- Body -->
  <div class="md:col-span-7 p-8 md:p-10 flex flex-col justify-center">
    <span class="text-[0.67rem] font-semibold tracking-wider uppercase text-brand-primary bg-brand-primary-light px-3 py-1.5 rounded border border-brand-primary/12 inline-block w-fit mb-4">
      {tag}
    </span>
    <h2 class="font-heading text-xl md:text-2xl font-semibold leading-snug tracking-tight text-text-primary mb-3">
      {title}
    </h2>
    <p class="text-sm text-text-muted leading-relaxed mb-5">
      {description}
    </p>

    <div class="flex gap-6 py-4 border-t border-b border-slate-100 mb-4">
      <div class="flex flex-col gap-0.5">
        <span class="font-heading text-lg font-medium text-text-primary tracking-tight">100+</span>
        <span class="text-[0.65rem] text-text-muted">Payers graded</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="font-heading text-lg font-medium text-text-primary tracking-tight">3</span>
        <span class="text-[0.65rem] text-text-muted">Compliance dimensions</span>
      </div>
      <div class="flex flex-col gap-0.5">
        <span class="font-heading text-lg font-medium text-text-primary tracking-tight">Q1 '26</span>
        <span class="text-[0.65rem] text-text-muted">Latest update</span>
      </div>
    </div>

    <span class="inline-flex items-center gap-2 text-sm font-medium text-brand-primary group-hover:gap-3 transition-all duration-200">
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>
