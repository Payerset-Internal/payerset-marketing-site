---
/**
 * NetworkViz.astro
 *
 * Mini network visualization for "Health Plan to NPI Network Adequacy" section.
 * Dark card showing a health plan with a grid of provider NPI dots
 * colored by in-network / out-of-network status.
 * Self-activates via IntersectionObserver on scroll.
 */
---

<div class="net-viz" id="networkViz">
  <div class="net-viz__card">
    <div class="net-viz__header">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="5" r="3" stroke="currentColor" stroke-width="1"/><path d="M3 14c0-2.761 2.239-5 5-5s5 2.239 5 5" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
      <span>Network Adequacy</span>
    </div>

    <!-- Plan header -->
    <div class="net-viz__plan" data-plan>
      <div class="net-viz__plan-badge">
        <span class="net-viz__plan-dot"></span>
        <div class="net-viz__plan-info">
          <span class="net-viz__plan-name">Anthem Blue Cross PPO</span>
          <span class="net-viz__plan-meta">Q1 2026 · National Network</span>
        </div>
      </div>
    </div>

    <!-- Provider grid -->
    <div class="net-viz__grid-section">
      <div class="net-viz__grid-label">
        <span>Provider NPIs</span>
        <div class="net-viz__legend">
          <span class="net-viz__legend-item"><span class="net-viz__legend-dot net-viz__legend-dot--in"></span>In-network</span>
          <span class="net-viz__legend-item"><span class="net-viz__legend-dot net-viz__legend-dot--out"></span>Out-of-network</span>
        </div>
      </div>
      <div class="net-viz__grid" id="netGrid">
        <!-- 48 dots generated by script -->
      </div>
    </div>

    <!-- Stats row -->
    <div class="net-viz__stats">
      <div class="net-viz__stats-item">
        <span class="net-viz__stats-value net-viz__stats-value--in" id="netInCount">—</span>
        <span class="net-viz__stats-label">in-network</span>
      </div>
      <div class="net-viz__stats-divider"></div>
      <div class="net-viz__stats-item">
        <span class="net-viz__stats-value net-viz__stats-value--out" id="netOutCount">—</span>
        <span class="net-viz__stats-label">out-of-network</span>
      </div>
      <div class="net-viz__stats-divider"></div>
      <div class="net-viz__stats-item">
        <span class="net-viz__stats-value" id="netCoverage">—</span>
        <span class="net-viz__stats-label">coverage rate</span>
      </div>
    </div>

    <div class="net-viz__footer">
      <span class="net-viz__ticker-dot"></span>
      <span>Tracked over 12 quarterly snapshots</span>
    </div>
  </div>
</div>

<style>
  .net-viz {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .net-viz__card {
    width: 100%;
    max-width: 480px;
    background: rgba(0, 31, 41, 0.95);
    border: 1px solid rgba(0, 183, 253, 0.2);
    border-radius: 16px;
    padding: 20px;
    box-shadow: 0 0 60px rgba(0, 183, 253, 0.06), 0 24px 48px rgba(0, 0, 0, 0.4);
  }

  .net-viz__header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .net-viz__header svg {
    color: var(--color-brand-secondary);
    opacity: 0.6;
  }

  .net-viz__plan {
    margin-bottom: 16px;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }

  .net-viz__plan.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .net-viz__plan-badge {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(59, 130, 246, 0.08);
    border: 1px solid rgba(59, 130, 246, 0.2);
    border-radius: 10px;
    padding: 10px 14px;
  }

  .net-viz__plan-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #3b82f6;
    flex-shrink: 0;
    box-shadow: 0 0 8px rgba(59, 130, 246, 0.4);
  }

  .net-viz__plan-info {
    display: flex;
    flex-direction: column;
  }

  .net-viz__plan-name {
    font-size: 12px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }

  .net-viz__plan-meta {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.35);
  }

  .net-viz__grid-section {
    margin-bottom: 14px;
  }

  .net-viz__grid-label {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
    font-size: 9px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.3);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .net-viz__legend {
    display: flex;
    gap: 12px;
  }

  .net-viz__legend-item {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 9px;
    color: rgba(255, 255, 255, 0.35);
    text-transform: none;
    letter-spacing: 0;
    font-weight: 400;
  }

  .net-viz__legend-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
  }

  .net-viz__legend-dot--in {
    background: #10b981;
  }

  .net-viz__legend-dot--out {
    background: rgba(255, 255, 255, 0.15);
  }

  .net-viz__grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 5px;
  }

  .net-viz__dot {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    opacity: 0;
    transform: scale(0);
    transition: opacity 0.3s ease, transform 0.3s ease, background 0.4s ease, box-shadow 0.4s ease;
  }

  .net-viz__dot.is-visible {
    opacity: 1;
    transform: scale(1);
  }

  .net-viz__dot.is-in {
    background: #10b981;
    box-shadow: 0 0 4px rgba(16, 185, 129, 0.3);
  }

  .net-viz__dot.is-out {
    background: rgba(255, 255, 255, 0.12);
  }

  .net-viz__stats {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 0;
  }

  .net-viz__stats-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .net-viz__stats-value {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    font-family: ui-monospace, SFMono-Regular, monospace;
    letter-spacing: -0.3px;
  }

  .net-viz__stats-value--in {
    color: #10b981;
  }

  .net-viz__stats-value--out {
    color: rgba(255, 255, 255, 0.5);
  }

  .net-viz__stats-label {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.3);
  }

  .net-viz__stats-divider {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.08);
  }

  .net-viz__footer {
    display: flex;
    align-items: center;
    gap: 6px;
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 10px;
    color: rgba(255, 255, 255, 0.35);
  }

  .net-viz__ticker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #10b981;
    box-shadow: 0 0 8px #10b981;
    animation: netPulse 2s ease-in-out infinite;
  }

  @keyframes netPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  @media (prefers-reduced-motion: reduce) {
    .net-viz__plan, .net-viz__dot {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .net-viz__ticker-dot {
      animation: none;
    }
  }
</style>

<script>
  const nvViz = document.getElementById('networkViz');
  if (nvViz) {
    const grid = document.getElementById('netGrid');
    const plan = nvViz.querySelector('[data-plan]');
    const inCount = document.getElementById('netInCount') as HTMLElement;
    const outCount = document.getElementById('netOutCount') as HTMLElement;
    const coverage = document.getElementById('netCoverage') as HTMLElement;
    let activated = false;

    // Create 48 dots
    const totalDots = 48;
    const inNetworkCount = 38;
    const dotStates: boolean[] = [];

    // Randomly assign in/out status
    for (let i = 0; i < totalDots; i++) {
      dotStates.push(i < inNetworkCount);
    }
    // Shuffle
    for (let i = dotStates.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [dotStates[i], dotStates[j]] = [dotStates[j], dotStates[i]];
    }

    // Create dot elements
    if (grid) {
      dotStates.forEach((isIn) => {
        const dot = document.createElement('div');
        dot.className = 'net-viz__dot';
        dot.dataset.in = isIn ? '1' : '0';
        grid.appendChild(dot);
      });
    }

    const dots = nvViz.querySelectorAll('.net-viz__dot');

    function activateNet() {
      if (activated) return;
      activated = true;

      // Show plan badge
      setTimeout(() => plan?.classList.add('is-visible'), 200);

      // Animate dots appearing in a wave
      dots.forEach((dot, i) => {
        const row = Math.floor(i / 12);
        const col = i % 12;
        const delay = 400 + (row * 80) + (col * 30);

        setTimeout(() => {
          dot.classList.add('is-visible');
          // Color after appearing
          setTimeout(() => {
            dot.classList.add((dot as HTMLElement).dataset.in === '1' ? 'is-in' : 'is-out');
          }, 150);
        }, delay);
      });

      // Show stats
      const statDelay = 400 + 4 * 80 + 12 * 30 + 300;
      setTimeout(() => {
        if (inCount) inCount.textContent = '2,847';
        if (outCount) outCount.textContent = '753';
        if (coverage) coverage.textContent = '79.1%';
      }, statDelay);
    }

    const io = new IntersectionObserver(
      (entries) => {
        if (entries[0]?.isIntersecting) activateNet();
      },
      { threshold: 0.2 }
    );
    io.observe(nvViz);
  }
</script>
