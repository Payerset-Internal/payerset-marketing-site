<style>
  /* ── Map Visual Container ── */
  .hero-map__visual {
    position: relative;
    opacity: 0;
    animation: hmFadeIn 1s cubic-bezier(0.23, 1, 0.32, 1) 0.3s forwards;
  }

  .hero-map__map-container {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 11;
    overflow: visible;
  }

  .hero-map__svg {
    width: 100%;
    height: 100%;
  }

  /* ── Grid pattern ── */
  .hero-map__grid {
    opacity: 0;
    animation: hmFadeIn 1.5s ease 0.6s forwards;
  }

  /* ── US Map paths ── */
  .hero-map__us-fill {
    fill: url(#hmMapFill);
    stroke: none;
    opacity: 0;
    animation: hmFadeIn 1.2s ease 0.5s forwards;
  }

  .hero-map__us-states {
    fill: none;
    stroke: var(--color-brand-secondary);
    stroke-opacity: 0.05;
    stroke-width: 0.5;
    stroke-linejoin: round;
    opacity: 0;
    animation: hmFadeIn 1.4s ease 0.6s forwards;
  }

  .hero-map__us-outline {
    fill: none;
    stroke: var(--color-brand-secondary);
    stroke-opacity: 0.15;
    stroke-width: 1.2;
    stroke-linejoin: round;
    opacity: 0;
    animation: hmFadeIn 1.2s ease 0.5s forwards;
  }

  .hero-map__scatter {
    opacity: 0;
    animation: hmFadeIn 1.5s ease 0.8s forwards;
  }

  /* ── Data flow lines ── */
  .hero-map__data-lines {
    opacity: 0;
    animation: hmFadeIn 1s ease 1.3s forwards;
  }

  .hero-map__data-line {
    stroke: var(--color-brand-secondary);
    stroke-width: 0.6;
    stroke-opacity: 0.1;
    stroke-dasharray: 6 8;
    animation: hmDash 12s linear infinite;
  }

  /* ── Passive cities ── */
  .hero-map__passive-cities {
    opacity: 0;
    animation: hmFadeIn 1.8s ease 1.0s forwards;
  }

  .hero-map__passive-ring {
    fill: none;
    stroke: var(--color-brand-secondary);
    stroke-width: 0.5;
    opacity: 0.2;
  }

  .hero-map__passive-dot {
    fill: var(--color-brand-secondary);
    opacity: 0.4;
  }

  .hero-map__passive-label {
    fill: rgba(255, 255, 255, 0.28);
    font-size: 10px;
    font-weight: 500;
    font-family: var(--font-sans);
    letter-spacing: 0.8px;
    text-transform: uppercase;
  }

  /* ── Hotspots ── */
  .hero-map__hotspot {
    cursor: pointer;
    opacity: 0;
    animation: hmFadeIn 0.8s ease forwards;
  }

  .hero-map__hotspot[data-market="0"] { animation-delay: 0.7s; }
  .hero-map__hotspot[data-market="1"] { animation-delay: 0.85s; }
  .hero-map__hotspot[data-market="2"] { animation-delay: 1.0s; }
  .hero-map__hotspot[data-market="3"] { animation-delay: 1.15s; }

  .hero-map__pulse-ring {
    fill: none;
    stroke: var(--color-brand-secondary);
    stroke-width: 0.6;
    opacity: 0.12;
    animation: hmPulse 3s ease-in-out infinite;
    transition: opacity 0.4s ease, r 0.4s ease;
  }

  .hero-map__hotspot.is-active .hero-map__pulse-ring {
    opacity: 0.35;
    stroke-width: 0.8;
  }

  .hero-map__mid-ring {
    fill: rgba(0, 183, 253, 0.08);
    stroke: var(--color-brand-secondary);
    stroke-width: 0.6;
    opacity: 0.25;
    transition: all 0.4s ease;
  }

  .hero-map__hotspot.is-active .hero-map__mid-ring {
    opacity: 0.7;
    stroke-width: 1.5;
    r: 10;
    filter: url(#hmDotGlow);
  }

  .hero-map__center-dot {
    fill: var(--color-brand-secondary);
    opacity: 0.5;
    transition: all 0.3s ease;
  }

  .hero-map__hotspot.is-active .hero-map__center-dot {
    opacity: 1;
    r: 4.5;
    filter: url(#hmDotGlow);
  }

  .hero-map__market-label {
    fill: rgba(255, 255, 255, 0.35);
    font-size: 11px;
    font-weight: 500;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    transition: all 0.3s ease;
  }

  .hero-map__hotspot.is-active .hero-map__market-label {
    fill: var(--color-brand-secondary);
    font-weight: 600;
    font-size: 11.5px;
  }

  /* ── Connector line ── */
  .hero-map__connector {
    stroke: var(--color-brand-secondary);
    stroke-width: 0.6;
    stroke-dasharray: 4 4;
    opacity: 0;
    transition: opacity 0.15s ease;
  }

  .hero-map__connector.is-visible {
    opacity: 0.25;
    transition: opacity 0.4s ease 0.15s;
  }

  /* ── Insight Panel ── */
  .hero-map__insight {
    position: absolute;
    width: 225px;
    background: rgba(0, 31, 41, 0.95);
    border: 1px solid rgba(0, 183, 253, 0.3);
    border-radius: 14px;
    padding: 18px;
    box-shadow: 0 0 50px rgba(0, 183, 253, 0.07), 0 24px 48px rgba(0, 0, 0, 0.45);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 10;
    transform: scale(0.96);
  }

  .hero-map__insight.is-visible {
    opacity: 1;
    transform: scale(1);
    transition: opacity 0.35s cubic-bezier(0.23, 1, 0.32, 1) 0.05s,
                transform 0.35s cubic-bezier(0.23, 1, 0.32, 1) 0.05s;
  }

  .hero-map__insight-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .hero-map__insight-code {
    display: inline-block;
    padding: 2px 8px;
    background: linear-gradient(135deg, var(--color-brand-secondary), var(--color-brand-primary));
    border-radius: 5px;
    font-size: 11px;
    font-weight: 700;
    color: var(--color-brand-dark-deep);
    font-family: ui-monospace, SFMono-Regular, monospace;
  }

  .hero-map__insight-market {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.8px;
    font-weight: 500;
  }

  .hero-map__insight-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.35);
    margin-bottom: 3px;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .hero-map__insight-rate {
    font-size: 24px;
    font-weight: 700;
    color: #ffffff;
    font-family: ui-monospace, SFMono-Regular, monospace;
    letter-spacing: -1px;
    margin-bottom: 12px;
  }

  .hero-map__insight-provider {
    font-size: 12px;
    color: rgba(255, 255, 255, 0.75);
    line-height: 1.4;
  }

  .hero-map__insight-payer {
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 12px;
  }

  .hero-map__insight-footer {
    padding-top: 12px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .hero-map__insight-footer-label {
    font-size: 9px;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .hero-map__insight-footer-count {
    font-size: 12px;
    color: var(--color-brand-primary);
    font-weight: 600;
    font-family: ui-monospace, SFMono-Regular, monospace;
  }

  /* ── Ticker ── */
  .hero-map__ticker {
    position: absolute;
    bottom: 8px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
    animation: hmFadeIn 0.8s ease 1.5s forwards;
  }

  .hero-map__ticker-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #00e87b;
    box-shadow: 0 0 8px #00e87b;
    animation: hmTickerPulse 2s ease-in-out infinite;
  }

  .hero-map__ticker-text {
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.6);
    letter-spacing: 0.3px;
  }

  /* ── Animations ── */
  @keyframes hmFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @keyframes hmPulse {
    0%, 100% { r: 18; opacity: 0.12; }
    50% { r: 24; opacity: 0.06; }
  }

  @keyframes hmDash {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -140; }
  }

  @keyframes hmTickerPulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .hero-map__visual {
      width: 100%;
      max-width: 560px;
      margin: 0 auto;
    }

    .hero-map__insight {
      width: 190px;
      padding: 14px;
    }

    .hero-map__insight-rate {
      font-size: 20px;
    }
  }

  @media (max-width: 640px) {
    .hero-map__insight {
      width: 170px;
      padding: 12px;
      border-radius: 10px;
    }

    .hero-map__insight-rate {
      font-size: 18px;
      margin-bottom: 8px;
    }

    .hero-map__insight-provider {
      font-size: 11px;
    }

    .hero-map__insight-payer {
      font-size: 9.5px;
      margin-bottom: 8px;
    }

    .hero-map__insight-footer {
      padding-top: 8px;
    }

    .hero-map__connector {
      display: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const markets = [
      {
        code: '29827',
        label: 'Miami',
        rate: '$19,324',
        provider: 'Cleveland Clinic',
        payer: 'Aetna',
        count: '48,200',
        cx: 819, cy: 566,
      },
      {
        code: '27447',
        label: 'Chicago',
        rate: '$14,891',
        provider: 'Rush University Medical Center',
        payer: 'BCBS Illinois',
        count: '62,100',
        cx: 632, cy: 215,
      },
      {
        code: '43239',
        label: 'Dallas–Fort Worth',
        rate: '$22,150',
        provider: 'Baylor Scott & White',
        payer: 'UnitedHealthcare',
        count: '55,400',
        cx: 471, cy: 432,
      },
      {
        code: '70553',
        label: 'Boston',
        rate: '$26,712',
        provider: 'Mass General Brigham',
        payer: 'Harvard Pilgrim',
        count: '41,800',
        cx: 905, cy: 156,
      },
    ];

    const hotspots = document.querySelectorAll('.hero-map__hotspot');
    const insight = document.getElementById('hmInsight');
    const connector = document.getElementById('hmConnector');
    const els = {
      code: document.getElementById('hmCode'),
      market: document.getElementById('hmMarket'),
      rate: document.getElementById('hmRate'),
      provider: document.getElementById('hmProvider'),
      payer: document.getElementById('hmPayer'),
    };

    let currentIdx = -1;
    let cycleTimer = null;
    let isHovering = false;
    let pendingTimeout = null;

    function positionInsight(m) {
      // Convert SVG coords (960x600) to percentages of the container
      const xPct = (m.cx / 960) * 100;
      const yPct = (m.cy / 600) * 100;

      // Get card dimensions as % of container
      const container = document.querySelector('.hero-map__map-container');
      const containerW = container.offsetWidth;
      const containerH = container.offsetHeight;
      const cardW = insight.offsetWidth || 225;
      const cardH = insight.offsetHeight || 210;
      const cardWPct = (cardW / containerW) * 100;
      const cardHPct = (cardH / containerH) * 100;

      // Place card to the left or right of the hotspot
      let leftPct, topPct;
      const offsetX = 4;

      if (m.cx > 480) {
        leftPct = xPct - cardWPct - offsetX;
      } else {
        leftPct = xPct + offsetX;
      }

      // Vertically center card on the hotspot, clamped to container
      topPct = yPct - (cardHPct / 2);
      topPct = Math.max(2, Math.min(topPct, 100 - cardHPct - 2));
      leftPct = Math.max(0, Math.min(leftPct, 100 - cardWPct));

      insight.style.left = leftPct + '%';
      insight.style.top = topPct + '%';
      insight.style.right = 'auto';
    }

    function activateMarket(idx) {
      if (idx === currentIdx) return;
      currentIdx = idx;
      const m = markets[idx];

      // Update hotspot states
      hotspots.forEach((h, i) => {
        h.classList.toggle('is-active', i === idx);
      });

      // Cancel any pending transition from a previous rapid switch
      if (pendingTimeout) clearTimeout(pendingTimeout);

      // Fade out card + connector
      insight.classList.remove('is-visible');
      connector.classList.remove('is-visible');

      // After brief fade-out, update content + position and fade back in
      pendingTimeout = setTimeout(() => {
        els.code.textContent = m.code;
        els.market.textContent = m.label;
        els.rate.textContent = m.rate;
        els.provider.textContent = m.provider;
        els.payer.textContent = m.payer;

        positionInsight(m);
        insight.classList.add('is-visible');

        // Update connector: short line from hotspot toward the card
        const connectorTargetX = m.cx > 480 ? m.cx - 50 : m.cx + 50;
        connector.setAttribute('x1', m.cx);
        connector.setAttribute('y1', m.cy);
        connector.setAttribute('x2', connectorTargetX);
        connector.setAttribute('y2', m.cy);
        connector.classList.add('is-visible');

        pendingTimeout = null;
      }, 160);
    }

    function startCycle() {
      activateMarket(0);
      cycleTimer = setInterval(() => {
        if (isHovering) return;
        const next = (currentIdx + 1) % markets.length;
        activateMarket(next);
      }, 3000);
    }

    // Hover interaction
    hotspots.forEach((h, i) => {
      h.addEventListener('mouseenter', () => {
        isHovering = true;
        activateMarket(i);
      });
      h.addEventListener('mouseleave', () => {
        isHovering = false;
      });
    });

    // Start auto-cycle after initial load animation
    setTimeout(startCycle, 1200);
  });
</script>
