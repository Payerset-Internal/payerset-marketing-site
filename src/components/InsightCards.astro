---
/**
 * InsightCards.astro
 *
 * "From national coverage to individual rates" section.
 * Layered background cards with a focal insight panel.
 * Scroll-triggered entrance animation via IntersectionObserver.
 *
 * Placed between the trust bar and solutions feature grid.
 */
---

<section class="insight-cards" id="insightCards">
  <!-- Luminous separator line at top -->
  <div class="insight-cards__separator"></div>

  <div class="insight-cards__inner">
    <!-- Section header -->
    <div class="insight-cards__header">
      <p class="insight-cards__eyebrow">From national coverage to individual rates</p>
      <h2 class="insight-cards__title">
        Every payer. Every provider.<br />Every negotiated rate.
      </h2>
      <p class="insight-cards__subtitle">
        Drill from market-level views into the exact dollar amount negotiated between any payer and provider — for any billing code, any plan.
      </p>
    </div>

    <!-- Visual area -->
    <div class="insight-cards__visual">
      <!-- Background layer cards -->
      <div class="insight-cards__layer insight-cards__layer--payers" data-reveal="layer">
        <div class="insight-cards__layer-label">Payers</div>
        <div class="insight-cards__layer-items">
          <span>UnitedHealthcare</span>
          <span>Aetna</span>
          <span>Cigna</span>
          <span>Blue Cross Blue Shield</span>
          <span>Humana</span>
          <span>Centene</span>
        </div>
      </div>

      <div class="insight-cards__layer insight-cards__layer--providers" data-reveal="layer">
        <div class="insight-cards__layer-label">Providers</div>
        <div class="insight-cards__layer-items">
          <span>Cleveland Clinic</span>
          <span>HCA Healthcare</span>
          <span>Tenet Health</span>
          <span>Trinity Health</span>
          <span>CommonSpirit</span>
        </div>
      </div>

      <div class="insight-cards__layer insight-cards__layer--codes" data-reveal="layer">
        <div class="insight-cards__layer-label">Billing Codes</div>
        <div class="insight-cards__layer-items">
          <span>29827</span>
          <span>99213</span>
          <span>27447</span>
          <span>43239</span>
          <span>70553</span>
          <span>99285</span>
        </div>
      </div>

      <!-- Connecting lines SVG -->
      <svg class="insight-cards__lines" viewBox="0 0 800 500" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
        <line x1="180" y1="140" x2="310" y2="200" stroke="var(--color-brand-secondary)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.15" />
        <line x1="620" y1="120" x2="500" y2="190" stroke="var(--color-brand-secondary)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.15" />
        <line x1="160" y1="370" x2="295" y2="330" stroke="var(--color-brand-secondary)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.15" />
        <line x1="640" y1="380" x2="510" y2="320" stroke="var(--color-brand-secondary)" stroke-width="0.5" stroke-dasharray="4 4" opacity="0.15" />
      </svg>

      <!-- Focal insight card -->
      <div class="insight-cards__focal" data-reveal="focal">
        <!-- Top accent -->
        <div class="insight-cards__focal-accent"></div>

        <!-- Code header -->
        <div class="insight-cards__focal-header">
          <div class="insight-cards__focal-header-top">
            <span class="insight-cards__focal-code">29827</span>
            <span class="insight-cards__focal-market">South Florida</span>
          </div>
          <div class="insight-cards__focal-desc">
            Arthroscopy, Shoulder — Rotator Cuff Repair
          </div>
        </div>

        <div class="insight-cards__focal-divider"></div>

        <!-- Rate rows -->
        <div class="insight-cards__focal-rates">
          <div class="insight-cards__rate-row" data-reveal="rate">
            <div class="insight-cards__rate-info">
              <div class="insight-cards__rate-provider">Cleveland Clinic</div>
              <div class="insight-cards__rate-payer">UnitedHealthcare</div>
            </div>
            <div class="insight-cards__rate-value">$18,143</div>
          </div>

          <div class="insight-cards__rate-row" data-reveal="rate">
            <div class="insight-cards__rate-info">
              <div class="insight-cards__rate-provider">Cleveland Clinic</div>
              <div class="insight-cards__rate-payer">Aetna</div>
            </div>
            <div class="insight-cards__rate-value">$19,324</div>
          </div>

          <div class="insight-cards__rate-row" data-reveal="rate">
            <div class="insight-cards__rate-info">
              <div class="insight-cards__rate-provider">HCA Healthcare</div>
              <div class="insight-cards__rate-payer">UnitedHealthcare</div>
            </div>
            <div class="insight-cards__rate-value">$19,422</div>
          </div>

          <div class="insight-cards__rate-row" data-reveal="rate">
            <div class="insight-cards__rate-info">
              <div class="insight-cards__rate-provider">Tenet Health</div>
              <div class="insight-cards__rate-payer">Aetna</div>
            </div>
            <div class="insight-cards__rate-value">$13,413</div>
          </div>
        </div>

        <!-- Footer -->
        <div class="insight-cards__focal-footer">
          <div class="insight-cards__focal-spread">
            <span class="insight-cards__focal-spread-label">Payer spread</span>
            <span class="insight-cards__focal-spread-value">+30%</span>
          </div>
          <a href="/rateexplorer" class="insight-cards__focal-more">
            View more rates →
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Section ── */
  .insight-cards {
    position: relative;
    width: 100%;
    padding: 0 0 120px;
    background: var(--color-brand-dark-deep);
    font-family: var(--font-sans);
    color: #ffffff;
    overflow: hidden;
  }

  /* ── Luminous separator ── */
  .insight-cards__separator {
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-brand-secondary), transparent);
    opacity: 0.3;
    margin-bottom: 90px;
  }

  .insight-cards__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  /* ── Header ── */
  .insight-cards__header {
    text-align: center;
    max-width: 640px;
    margin: 0 auto 70px;
  }

  .insight-cards__eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2.5px;
    color: var(--color-brand-primary);
    margin: 0 0 16px;
  }

  .insight-cards__title {
    font-family: var(--font-heading);
    font-size: clamp(1.6rem, 3.2vw, 2.4rem);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 18px;
  }

  .insight-cards__subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Visual Area ── */
  .insight-cards__visual {
    position: relative;
    max-width: 820px;
    height: 500px;
    margin: 0 auto;
  }

  /* ── Layer Cards ── */
  .insight-cards__layer {
    position: absolute;
    width: 210px;
    padding: 16px 18px;
    background: rgba(0, 31, 41, 0.55);
    border: 1px solid rgba(0, 183, 253, 0.12);
    border-radius: 12px;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: all 0.9s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .insight-cards__layer.is-revealed {
    opacity: 0.3;
  }

  .insight-cards__layer--payers {
    top: 5%;
    left: 0;
    transform: rotate(-7deg) translate(-20px, 10px);
  }

  .insight-cards__layer--payers.is-revealed {
    transform: rotate(-7deg) translate(0, 0);
  }

  .insight-cards__layer--providers {
    top: 0%;
    right: 0;
    transform: rotate(5deg) translate(20px, -10px);
  }

  .insight-cards__layer--providers.is-revealed {
    transform: rotate(5deg) translate(0, 0);
  }

  .insight-cards__layer--codes {
    bottom: 8%;
    left: 2%;
    transform: rotate(-3deg) translate(-15px, 15px);
  }

  .insight-cards__layer--codes.is-revealed {
    transform: rotate(-3deg) translate(0, 0);
  }

  .insight-cards__layer-label {
    font-size: 9px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    color: var(--color-brand-primary);
    margin-bottom: 10px;
  }

  .insight-cards__layer-items span {
    display: block;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.35);
    padding: 3.5px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  }

  .insight-cards__layer-items span:last-child {
    border-bottom: none;
  }

  /* Billing codes as inline chips */
  .insight-cards__layer--codes .insight-cards__layer-items {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .insight-cards__layer--codes .insight-cards__layer-items span {
    display: inline-block;
    padding: 3px 8px;
    border: 1px solid rgba(0, 183, 253, 0.1);
    border-radius: 5px;
    font-family: ui-monospace, SFMono-Regular, monospace;
    font-size: 10px;
    color: rgba(255, 255, 255, 0.35);
  }

  /* ── Connecting Lines ── */
  .insight-cards__lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 2;
    opacity: 0;
    transition: opacity 1s ease 0.6s;
  }

  .insight-cards__visual.is-in-view .insight-cards__lines {
    opacity: 1;
  }

  /* ── Focal Card ── */
  .insight-cards__focal {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) scale(0.95);
    width: 400px;
    background: linear-gradient(135deg, rgba(3, 45, 68, 0.96), rgba(0, 31, 41, 0.98));
    border: 1px solid rgba(0, 183, 253, 0.3);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 0 70px rgba(0, 183, 253, 0.07), 0 30px 60px rgba(0, 0, 0, 0.4);
    z-index: 5;
    opacity: 0;
    transition: all 1s cubic-bezier(0.23, 1, 0.32, 1) 0.3s;
  }

  .insight-cards__focal.is-revealed {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1);
  }

  .insight-cards__focal-accent {
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-brand-secondary), transparent);
  }

  /* Focal header */
  .insight-cards__focal-header {
    padding: 20px 24px 14px;
  }

  .insight-cards__focal-header-top {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }

  .insight-cards__focal-code {
    display: inline-block;
    padding: 3px 10px;
    background: linear-gradient(135deg, var(--color-brand-secondary), var(--color-brand-primary));
    border-radius: 6px;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-brand-dark-deep);
    font-family: ui-monospace, SFMono-Regular, monospace;
  }

  .insight-cards__focal-market {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .insight-cards__focal-desc {
    font-size: 13px;
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.35;
  }

  .insight-cards__focal-divider {
    height: 1px;
    background: rgba(255, 255, 255, 0.06);
    margin: 0 24px;
  }

  /* Rate rows */
  .insight-cards__focal-rates {
    padding: 14px 24px;
  }

  .insight-cards__rate-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 12px;
    margin-bottom: 3px;
    border-radius: 8px;
    transition: background 0.2s ease;
    opacity: 0;
    transform: translateX(12px);
  }

  .insight-cards__rate-row.is-revealed {
    opacity: 1;
    transform: translateX(0);
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
  }

  .insight-cards__rate-row:hover {
    background: rgba(0, 183, 253, 0.05);
  }

  .insight-cards__rate-provider {
    font-size: 12.5px;
    color: #ffffff;
    font-weight: 500;
  }

  .insight-cards__rate-payer {
    font-size: 10.5px;
    color: rgba(255, 255, 255, 0.6);
    margin-top: 2px;
  }

  .insight-cards__rate-value {
    font-size: 16px;
    font-weight: 600;
    color: #ffffff;
    font-family: ui-monospace, SFMono-Regular, monospace;
    letter-spacing: -0.5px;
  }

  /* Footer */
  .insight-cards__focal-footer {
    padding: 14px 24px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
  }

  .insight-cards__focal-spread {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .insight-cards__focal-spread-label {
    font-size: 10px;
    color: rgba(255, 255, 255, 0.35);
    text-transform: uppercase;
    letter-spacing: 0.8px;
  }

  .insight-cards__focal-spread-value {
    font-size: 12px;
    font-weight: 600;
    color: #ff4d6a;
    font-family: ui-monospace, SFMono-Regular, monospace;
  }

  .insight-cards__focal-more {
    font-size: 10.5px;
    color: var(--color-brand-primary);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .insight-cards__focal-more:hover {
    color: var(--color-brand-secondary);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .insight-cards__visual {
      height: 440px;
    }

    .insight-cards__layer--providers {
      right: -10px;
    }

    .insight-cards__focal {
      width: 340px;
    }
  }

  @media (max-width: 640px) {
    .insight-cards {
      padding: 0 0 80px;
    }

    .insight-cards__separator {
      margin-bottom: 60px;
    }

    .insight-cards__layer {
      display: none;
    }

    .insight-cards__lines {
      display: none;
    }

    .insight-cards__visual {
      height: auto;
    }

    .insight-cards__focal {
      position: relative;
      top: auto;
      left: auto;
      transform: none;
      width: 100%;
      max-width: 400px;
      margin: 0 auto;
    }

    .insight-cards__focal.is-revealed {
      transform: none;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('insightCards');
    if (!section) return;

    const visual = section.querySelector('.insight-cards__visual');
    const layers = section.querySelectorAll('[data-reveal="layer"]');
    const focal = section.querySelector('[data-reveal="focal"]');
    const rates = section.querySelectorAll('[data-reveal="rate"]');

    let hasRevealed = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !hasRevealed) {
            hasRevealed = true;
            visual.classList.add('is-in-view');

            // Stagger layer reveals
            layers.forEach((layer, i) => {
              setTimeout(() => {
                layer.classList.add('is-revealed');
              }, 100 + i * 180);
            });

            // Focal card reveal
            setTimeout(() => {
              focal.classList.add('is-revealed');
            }, 500);

            // Stagger rate rows
            rates.forEach((rate, i) => {
              setTimeout(() => {
                rate.classList.add('is-revealed');
              }, 800 + i * 120);
            });
          }
        });
      },
      { threshold: 0.25 }
    );

    observer.observe(section);
  });
</script>
