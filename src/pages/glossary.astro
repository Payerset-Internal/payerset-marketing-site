---
import PageLayout from '../layouts/PageLayout.astro';

import { glossaryTerms as terms } from '../data/glossary';

const pageUrl = 'https://www.payerset.com/glossary';

const glossarySchema = {
  '@context': 'https://schema.org',
  '@type': 'DefinedTermSet',
  '@id': `${pageUrl}#termset`,
  name: 'Healthcare Price Transparency Glossary',
  description:
    'Definitions of key healthcare price transparency terms — including machine-readable files (MRFs), Transparency in Coverage, negotiated rates, and reimbursement benchmarking.',
  url: pageUrl,
  publisher: { '@id': 'https://www.payerset.com/#organization' },
  hasDefinedTerm: terms.map((t) => ({
    '@type': 'DefinedTerm',
    '@id': `${pageUrl}#${t.id}`,
    name: t.term,
    description: t.definition,
    inDefinedTermSet: `${pageUrl}#termset`,
    url: `${pageUrl}#${t.id}`,
  })),
};
---

<PageLayout
  title="Healthcare Price Transparency Glossary"
  description="Plain-language definitions of healthcare price transparency terms — MRFs, Transparency in Coverage (TiC), negotiated and allowed rates, reimbursement benchmarking, and more."
  extraSchema={[glossarySchema]}
>
  <!-- Hero -->
  <section class="relative bg-brand-dark-deep overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-brand-dark-deep"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
      <div class="max-w-3xl">
        <p class="text-sm font-semibold text-brand-secondary uppercase tracking-wider mb-3">
          Price Transparency Glossary
        </p>
        <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight">
          Healthcare Price Transparency Terms, Defined
        </h1>
        <p class="mt-6 text-lg text-slate-300 leading-relaxed">
          Clear, plain-language definitions of the terms you'll encounter when working with payer
          and hospital price transparency data — from machine-readable files (MRFs) and
          Transparency in Coverage to negotiated rates and reimbursement benchmarking.
        </p>
      </div>
    </div>
  </section>

  <!-- Quick nav -->
  <section class="bg-slate-50 border-b border-slate-200">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <nav aria-label="Glossary terms" class="flex flex-wrap gap-2">
        {terms.map((t) => (
          <a
            href={`#${t.id}`}
            class="inline-flex items-center rounded-full border border-slate-200 bg-white px-3.5 py-1.5 text-sm text-slate-600 hover:border-brand-primary/40 hover:text-brand-primary transition-colors"
          >
            {t.term}
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- Definitions -->
  <section class="py-16 lg:py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="space-y-10">
        {terms.map((t) => (
          <article id={t.id} class="scroll-mt-28">
            <h2 class="text-2xl font-semibold text-brand-dark">{t.term}</h2>
            <div class="mt-2 h-0.5 w-12 bg-gradient-to-r from-brand-secondary to-brand-primary rounded-full"></div>
            <p class="mt-4 text-base text-slate-600 leading-relaxed">{t.definition}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative overflow-hidden bg-brand-dark-deep">
    <div class="absolute inset-0 bg-gradient-to-tl from-brand-dark-deep via-brand-dark to-brand-dark-deeper"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_right,rgba(0,146,202,0.15),transparent_60%)]"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20 text-center">
      <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4">
        Put these concepts to work
      </h2>
      <p class="text-lg text-white/70 max-w-2xl mx-auto mb-8 font-light">
        See how Payerset turns payer and hospital machine-readable files into clean, analyzable
        rate data for benchmarking and contract negotiations.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <a
          href="/get-started"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-brand-dark-deep bg-white hover:bg-slate-100 rounded-lg transition-colors"
        >
          Request a demo
        </a>
        <a
          href="/pricetransparencyproject"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white border border-white/30 hover:border-white/60 rounded-lg transition-colors"
        >
          Explore the Price Transparency Project
        </a>
      </div>
    </div>
  </section>
</PageLayout>
