---
import { Image } from 'astro:assets';
import payersetLogoWhite from '../assets/images/payerset-logo-white.png';

const currentYear = new Date().getFullYear();

const footerLinks = {
  Solutions: [
    { label: 'Rate Explorer', href: '/rateexplorer' },
    { label: 'Data Lake', href: '/datalake' },
    { label: 'Snowflake Marketplace', href: '/snowflakemarketplace' },
  ],
  Resources: [
    { label: 'Blog', href: '/insights' },
    { label: 'Payercast', href: '/insights/categories/payercast' },
    { label: 'Payer Scorecard', href: 'https://docs.payerset.com/payers/aetna-price-transparency', external: true },
    { label: 'Data Dictionaries', href: 'https://docs.payerset.com/rate-explorer/data-dictionary', external: true },
  ],
  Company: [
    { label: 'About Us', href: '/about-us' },
    { label: 'Research', href: '/research' },
    { label: 'Pricing', href: '/pricing' },
    { label: 'Get Started', href: '/get-started' },
  ],
  Legal: [
    { label: 'Privacy Policy', href: '/privacy' },
  ],
};
---

<footer class="bg-brand-dark-deep text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-5 gap-8">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <a href="/">
          <Image src={payersetLogoWhite} alt="Payerset" class="h-6 w-auto" width={301} height={72} loading="lazy" />
        </a>
        <p class="mt-3 text-sm text-slate-400">
          The Healthcare Price Transparency Solution.
        </p>
      </div>

      <!-- Link Groups -->
      {Object.entries(footerLinks).map(([heading, links]) => (
        <div>
          <h3 class="text-sm font-semibold text-white uppercase tracking-wider mb-4">
            {heading}
          </h3>
          <ul class="space-y-2">
            {links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-400 hover:text-white transition-colors"
                  target={link.external ? '_blank' : undefined}
                  rel={link.external ? 'noopener noreferrer' : undefined}
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 pt-8 border-t border-brand-dark-deeper flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-500">
        &copy; {currentYear} Payerset LLC. All rights reserved.
      </p>
      <div class="flex items-center gap-4">
        <a href="https://www.linkedin.com/company/payerset" target="_blank" rel="noopener noreferrer" class="text-slate-500 hover:text-white transition-colors" aria-label="LinkedIn">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
