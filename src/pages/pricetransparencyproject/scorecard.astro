---
import PageLayout from '../../layouts/PageLayout.astro';
import data from '../../data/payers.json';

/**
 * Payer Compliance Scorecard
 * ---------------------------------------------------------------------------
 * Interactive lookup: visitors build a view of the payers in *their* market
 * (search + quick-add), compare them side by side, and open a detail panel for
 * the full breakdown. Data is generated by `npm run sync:scorecard` from the
 * Payerset Documentation GitBook -> src/data/payers.json.
 */

const payers = data.payers;
const totalCount = data.payerCount;

// Traffic-light -> dot color for the server-rendered "See all payers" list.
const DOT: Record<string, string> = {
  green: 'bg-emerald-500',
  yellow: 'bg-amber-400',
  orange: 'bg-orange-400',
  red: 'bg-rose-500',
};
const dotClass = (c: string | null) => (c && DOT[c]) || 'bg-slate-300';

// Default "market" shown on first load + one-tap quick-adds for the big names.
// Start with an empty workspace so the tool invites the user to build their own comparison.
const seedSlugs: string[] = [];
const quickAddSlugs = [
  'payers/aetna-price-transparency',
  'payers/cigna-price-transparency',
  'payers/united-healthcare-price-transparency',
  'payers/elevance-anthem-price-transparency',
  'payers/humana-price-transparency',
  'payers/kaiser-price-transparency',
  'payers/bcbs-texas-price-transparency',
  'payers/molina-price-transparency',
];
const bySlug = Object.fromEntries(payers.map((p) => [p.path, p]));
const quickAdd = quickAddSlugs
  .map((s) => bySlug[s])
  .filter(Boolean)
  .map((p) => ({ id: p.id, name: p.name }));
const seedIds = seedSlugs.map((s) => bySlug[s]?.id).filter(Boolean);

// Trim the payload sent to the client to just the fields the UI uses.
const clientPayers = payers.map((p) => ({
  id: p.id,
  name: p.name,
  schema: p.schema,
  url: p.url,
  tocUrl: p.tocUrl,
  hasScorecard: p.hasScorecard,
  overall: p.overall,
  categories: p.categories.map((c) => ({ name: c.name, score: c.score, max: c.max, color: c.color, criteria: c.criteria })),
  validation: p.validation,
  observations: p.observations,
  overallAssessment: p.overallAssessment,
  alerts: p.alerts,
  subPlanLinks: p.subPlanLinks,
  updatedAt: p.updatedAt,
}));
---

<PageLayout
  title="Payer Compliance Scorecard — The Price Transparency Project"
  description="See how the payers in your market score on price transparency. We grade 180+ payers on three dimensions of their machine-readable files: table of contents, file accessibility, and data quality."
>
  <!-- ===== App header ===== -->
  <header class="relative overflow-hidden bg-brand-dark-deep border-b border-white/10">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark-deep via-brand-dark to-brand-dark-deeper"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(0,146,202,0.22),transparent_55%)] pointer-events-none"></div>
    <div class="absolute inset-x-0 top-0 h-0.5 bg-gradient-to-r from-brand-primary via-brand-secondary to-brand-accent z-10"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-7">
      <div class="min-w-0">
        <a href="/pricetransparencyproject" class="inline-flex items-center gap-2 text-sm font-medium text-brand-accent mb-2.5 no-underline hover:text-white transition-colors w-fit">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-brand-accent"></span>
          </span>
          The Price Transparency Project
        </a>
        <h1 class="font-heading text-2xl sm:text-3xl font-bold text-white tracking-tight leading-none">Payer Compliance Scorecard</h1>
      </div>
    </div>
  </header>

  <!-- ===== Sticky control bar ===== -->
  <div class="sticky top-[72px] z-30 border-b border-slate-200/70 bg-surface-light/90 backdrop-blur-md shadow-[0_1px_8px_-4px_rgba(2,45,68,0.08)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex flex-col sm:flex-row sm:items-center gap-3">
      <!-- Search -->
      <div class="relative flex-1 sm:max-w-md" id="sc-search-wrap">
        <div class="relative">
          <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" width="18" height="18" viewBox="0 0 18 18" fill="none">
            <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"/>
            <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
          <input
            id="sc-search"
            type="text"
            autocomplete="off"
            placeholder="Search 180+ payers — Aetna, Blue Cross, UnitedHealthcare…"
            class="w-full pl-11 pr-4 py-2.5 text-sm rounded-lg border border-slate-300 bg-white text-text-primary placeholder:text-slate-400 focus:outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition"
          />
        </div>
        <ul id="sc-results" class="hidden absolute z-40 mt-1.5 w-full max-h-72 overflow-y-auto bg-white border border-slate-200 rounded-lg shadow-xl py-1"></ul>
      </div>
    </div>
  </div>

  <!-- ===== Workspace ===== -->
  <section class="relative bg-surface-light">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,rgba(0,146,202,0.06),transparent_50%)] pointer-events-none"></div>
    <div class="sc-dots absolute inset-0 pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Quick add -->
    <div class="flex flex-wrap items-start gap-2 mb-6" id="sc-quickadd">
      <span class="text-xs font-medium text-text-muted mr-1 py-1.5">Quick add</span>
      {quickAdd.map((p) => (
        <button
          type="button"
          data-add={p.id}
          class="sc-quick inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-full border border-slate-200 bg-white shadow-sm text-text-secondary hover:border-brand-primary hover:text-brand-primary hover:bg-brand-primary-light transition"
        >
          <span class="sc-quick-icon text-slate-400 text-sm leading-none">+</span>{p.name}
        </button>
      ))}

      <!-- See all payers (checkbox dropdown) + Clear all, stacked & right-aligned -->
      <div class="flex flex-col items-end gap-2">
      <div class="relative" id="sc-browse-wrap">
        <button
          type="button"
          id="sc-browse-toggle"
          class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-semibold rounded-full border border-dashed border-slate-300 bg-white shadow-sm text-text-secondary hover:border-brand-primary hover:text-brand-primary transition"
          aria-haspopup="true"
          aria-expanded="false"
        >
          See all {totalCount}
          <svg id="sc-browse-chevron" class="transition-transform" width="11" height="11" viewBox="0 0 12 12" fill="none"><path d="M3 4.5L6 7.5l3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>

        <div
          id="sc-browse-panel"
          class="hidden absolute right-0 z-40 mt-2 w-80 max-w-[calc(100vw-2rem)] flex flex-col rounded-xl border border-slate-200 bg-white shadow-xl"
        >
          <div class="p-2.5 border-b border-slate-100">
            <div class="relative">
              <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none" width="15" height="15" viewBox="0 0 18 18" fill="none">
                <circle cx="8" cy="8" r="5.5" stroke="currentColor" stroke-width="1.5"/>
                <path d="M12.5 12.5L16 16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
              <input
                id="sc-browse-filter"
                type="text"
                autocomplete="off"
                placeholder="Filter payers…"
                class="w-full pl-9 pr-3 py-2 text-sm rounded-lg border border-slate-200 bg-white text-text-primary placeholder:text-slate-400 focus:outline-none focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 transition"
              />
            </div>
          </div>
          <ul id="sc-browse-list" class="flex-1 overflow-y-auto py-1 max-h-72">
            {payers.map((p) => (
              <li class="sc-browse-row" data-id={p.id} data-name={p.name.toLowerCase()}>
                <label class="flex items-center gap-2.5 px-3 py-2 cursor-pointer hover:bg-slate-50 transition">
                  <input type="checkbox" class="sc-check shrink-0 h-4 w-4 rounded border-slate-300 text-brand-primary focus:ring-brand-primary/30 cursor-pointer" data-id={p.id} />
                  <span class={`w-2 h-2 rounded-full shrink-0 ${dotClass(p.overall.color)}`}></span>
                  <span class="flex-1 text-sm text-text-primary truncate">{p.name}</span>
                  <span class="text-[0.7rem] text-text-muted tabular-nums shrink-0">{p.overall.score != null ? `${p.overall.score}/${p.overall.max}` : '—'}</span>
                </label>
              </li>
            ))}
            <li id="sc-browse-noresults" class="hidden px-3 py-4 text-sm text-text-muted text-center">No payers match that filter.</li>
          </ul>
          <div class="flex items-center justify-between gap-2 px-3 py-2.5 border-t border-slate-100">
            <span id="sc-browse-count" class="text-xs text-text-muted tabular-nums">0 of 6 selected</span>
            <button type="button" id="sc-browse-done" class="text-xs font-semibold text-brand-primary hover:underline">Done</button>
          </div>
        </div>
      </div>

        <div class="flex items-center gap-3">
          <span id="sc-cap-note" class="hidden text-xs text-text-muted whitespace-nowrap"></span>
          <button id="sc-clear" type="button" class="hidden items-center text-xs font-medium text-text-muted hover:text-rose-600 transition whitespace-nowrap">Clear all</button>
        </div>
      </div>
    </div>

    <!-- Comparison grid. The trailing "Add a payer" ghost slot always shows where the
         next tile will land; JS keeps it last and hides it once the comparison is full. -->
    <div id="sc-grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      <div class="relative" id="sc-empty-anchor">
        <button
          type="button"
          id="sc-empty-add"
          class="w-full group flex flex-col items-center justify-center text-center gap-3 min-h-[280px] p-6 rounded-2xl border-2 border-dashed border-slate-300 bg-white/40 hover:border-brand-primary/60 hover:bg-brand-primary-light transition"
        >
          <span class="flex items-center justify-center w-12 h-12 rounded-xl bg-gradient-to-br from-brand-primary/15 to-brand-secondary/10 ring-1 ring-brand-primary/10 text-brand-primary group-hover:from-brand-primary/25 group-hover:to-brand-secondary/20 transition">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </span>
          <span class="font-heading text-base font-semibold text-text-primary">Add a payer</span>
          <span class="text-sm text-text-muted max-w-[14rem]">Pick from all {totalCount} payers, or search above.</span>
        </button>
      </div>
    </div>

    <!-- Legend -->
    <div class="mt-10 flex flex-wrap items-center gap-x-6 gap-y-2 text-xs text-text-muted">
      <span class="font-semibold text-xs text-text-secondary">Rating</span>
      <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-emerald-500"></span>Strong</span>
      <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-amber-400"></span>Acceptable</span>
      <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-orange-400"></span>Needs work</span>
      <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-rose-500"></span>Poor</span>
      <span class="inline-flex items-center gap-1.5"><span class="w-2.5 h-2.5 rounded-full bg-slate-300"></span>Not yet graded</span>
    </div>
    </div>
  </section>

  <!-- ===== Detail slide-over ===== -->
  <div id="sc-backdrop" class="fixed inset-0 bg-brand-dark-deep/50 backdrop-blur-sm z-50 opacity-0 pointer-events-none transition-opacity duration-300"></div>
  <aside
    id="sc-panel"
    class="fixed top-0 right-0 h-full w-full max-w-lg bg-white z-50 shadow-2xl translate-x-full transition-transform duration-300 ease-out overflow-y-auto"
    aria-hidden="true"
    role="dialog"
    aria-label="Payer scorecard detail"
  >
    <div id="sc-panel-content"></div>
  </aside>

  <!-- ===== Browse all (SEO + fallback) ===== -->
  <section class="relative overflow-hidden bg-brand-dark-deep">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark-deep via-brand-dark to-brand-dark-deeper"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom_left,rgba(0,146,202,0.18),transparent_55%)] pointer-events-none"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <details class="group">
        <summary class="cursor-pointer list-none flex items-center gap-2 font-heading text-base font-semibold text-white">
          <svg class="transition-transform group-open:rotate-90 text-brand-secondary" width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          Browse all {totalCount} payers
        </summary>
        <p class="mt-1.5 ml-6 text-sm text-slate-400">Every payer we track, linked to its full documentation.</p>
        <ul class="mt-5 grid sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1.5">
          {payers.map((p) => (
            <li>
              <a href={p.url} class="text-sm text-slate-300 hover:text-brand-secondary transition no-underline">{p.name}</a>
            </li>
          ))}
        </ul>
      </details>
    </div>
  </section>

  <script type="application/json" id="sc-data" set:html={JSON.stringify(clientPayers)} />
  <script type="application/json" id="sc-seed" set:html={JSON.stringify(seedIds)} />

  <script>
    type Criterion = { text: string; status: string };
    type Category = { name: string; score: number | null; max: number; color: string | null; criteria: Criterion[] };
    type Payer = {
      id: string; name: string; schema: string | null; url: string; tocUrl: string | null;
      hasScorecard: boolean;
      overall: { score: number | null; max: number; label: string | null; color: string | null };
      categories: Category[];
      validation: { providers: number | null; rates: number | null; bundledCodes: number | null; coveredServicesCapitation: number | null };
      observations: { label: string; status: string; text: string }[];
      overallAssessment: string | null;
      alerts: { severity: string; text: string }[];
      subPlanLinks: { label: string; url: string }[];
      updatedAt: string | null;
    };

    const MAX = 6;
    const STORAGE_KEY = 'payerset-scorecard-selection';

    const payers: Payer[] = JSON.parse(document.getElementById('sc-data')!.textContent || '[]');
    const seed: string[] = JSON.parse(document.getElementById('sc-seed')!.textContent || '[]');
    const byId = new Map(payers.map((p) => [p.id, p]));

    // ---- color system (maps GitBook traffic-light colors to brand-consistent tailwind) ----
    const COLORS: Record<string, { dot: string; text: string; soft: string }> = {
      green:  { dot: 'bg-emerald-500', text: 'text-emerald-600', soft: 'bg-emerald-50' },
      yellow: { dot: 'bg-amber-400',   text: 'text-amber-600',   soft: 'bg-amber-50' },
      orange: { dot: 'bg-orange-400',  text: 'text-orange-600',  soft: 'bg-orange-50' },
      red:    { dot: 'bg-rose-500',    text: 'text-rose-600',    soft: 'bg-rose-50' },
    };
    const NEUTRAL = { dot: 'bg-slate-300', text: 'text-slate-500', soft: 'bg-slate-50' };
    const color = (c: string | null) => (c && COLORS[c]) || NEUTRAL;

    const fmt = (n: number | null) => (n == null ? '—' : n.toLocaleString('en-US'));

    const escapeHtml = (s: string) =>
      s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');

    function starsHtml(score: number | null, max = 5, cls = 'text-amber-400') {
      if (score == null) return '';
      let out = '';
      for (let i = 1; i <= max; i++) {
        out += `<span class="${i <= score ? cls : 'text-slate-200'}">★</span>`;
      }
      return `<span class="text-sm tracking-tight" aria-label="${score} of ${max}">${out}</span>`;
    }

    // ---- state ----
    let selected: string[] = [];

    function load() {
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || 'null');
        if (Array.isArray(saved) && saved.length) {
          selected = saved.filter((id) => byId.has(id));
          return;
        }
      } catch {}
      selected = seed.slice();
    }
    function save() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(selected)); } catch {}
    }

    function add(id: string) {
      if (selected.includes(id) || !byId.has(id)) return;
      if (selected.length >= MAX) { flashCap(); return; }
      selected.push(id);
      save(); render();
    }
    function remove(id: string) {
      selected = selected.filter((s) => s !== id);
      save(); render();
    }

    // ---- card markup ----
    function cardHtml(p: Payer) {
      const oc = color(p.overall.color);
      let ratingBlock: string;
      if (p.overall.score != null) {
        ratingBlock = `
          <div class="flex items-end gap-2">
            <span class="font-heading text-3xl font-bold ${oc.text} leading-none">${p.overall.score}<span class="text-lg text-slate-300 font-semibold">/${p.overall.max}</span></span>
          </div>
          <div class="mt-1.5">${starsHtml(p.overall.score, p.overall.max, oc.text)}</div>
          ${p.overall.label ? `<div class="text-xs font-medium ${oc.text} mt-1">${escapeHtml(p.overall.label)}</div>` : ''}`;
      } else if (p.overall.label) {
        ratingBlock = `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium ${NEUTRAL.soft} ${NEUTRAL.text}"><span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>${escapeHtml(p.overall.label)}</span>`;
      } else {
        ratingBlock = `<span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium ${NEUTRAL.soft} ${NEUTRAL.text}"><span class="w-1.5 h-1.5 rounded-full bg-slate-400"></span>Not yet graded</span>`;
      }

      const dims = p.categories.length
        ? p.categories.map((c) => {
            const cc = color(c.color);
            const pct = c.score != null ? Math.round((c.score / (c.max || 5)) * 100) : 0;
            return `<div class="text-[0.8rem]">
              <div class="flex items-center justify-between gap-2 mb-1.5">
                <span class="text-text-secondary truncate">${escapeHtml(c.name)}</span>
                <span class="font-semibold ${cc.text} tabular-nums shrink-0">${c.score != null ? c.score + '/' + c.max : '—'}</span>
              </div>
              <div class="h-1.5 rounded-full bg-slate-100 overflow-hidden">
                <div class="sc-bar h-full rounded-full ${cc.dot}" data-pct="${pct}" style="width:0%"></div>
              </div>
            </div>`;
          }).join('')
        : `<div class="text-xs text-text-muted italic">Scorecard pending — see documentation.</div>`;

      const hasAlert = p.alerts.some((a) => a.severity === 'danger');

      return `<article class="sc-card payer-card group relative overflow-hidden bg-white rounded-2xl border border-slate-200/80 shadow-[0_1px_2px_rgba(2,45,68,0.04),0_10px_30px_-16px_rgba(2,45,68,0.18)] hover:shadow-[0_12px_40px_-12px_rgba(0,146,202,0.28)] hover:border-brand-primary/30 hover:-translate-y-1 p-5 pt-6" data-id="${p.id}">
        <span class="absolute inset-x-0 top-0 h-1 ${oc.dot}"></span>
        <button type="button" class="sc-remove absolute top-3.5 right-3 w-6 h-6 inline-flex items-center justify-center rounded-full text-slate-300 hover:text-rose-500 hover:bg-rose-50 transition" data-remove="${p.id}" aria-label="Remove ${escapeHtml(p.name)}">
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M2.5 2.5l7 7M9.5 2.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="pr-6">
          <h3 class="font-heading font-semibold text-text-primary leading-snug">${escapeHtml(p.name)}</h3>
          ${p.schema ? `<div class="text-[0.7rem] uppercase tracking-wide text-text-muted mt-0.5">${escapeHtml(p.schema)}</div>` : ''}
        </div>
        <div class="mt-4 min-h-[60px]">${ratingBlock}</div>
        <div class="mt-4 space-y-3 border-t border-slate-100 pt-4">${dims}</div>
        <button type="button" class="sc-details mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-brand-primary hover:gap-2.5 transition-all" data-details="${p.id}">
          View details
          ${hasAlert ? '<span class="w-1.5 h-1.5 rounded-full bg-rose-500" title="Has a compliance alert"></span>' : ''}
          <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
      </article>`;
    }

    // ---- render comparison grid ----
    const grid = document.getElementById('sc-grid')!;
    const emptyAnchor = document.getElementById('sc-empty-anchor')!;
    const capNote = document.getElementById('sc-cap-note')!;
    const clearBtn = document.getElementById('sc-clear')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // animate each dimension bar from 0 to its target width.
    // setTimeout (not rAF) so it still fires if the tab is backgrounded.
    function fillBars(card: HTMLElement) {
      card.querySelectorAll<HTMLElement>('.sc-bar').forEach((b) => {
        const pct = b.getAttribute('data-pct') || '0';
        if (reduceMotion) { b.style.width = pct + '%'; }
        else { setTimeout(() => { b.style.width = pct + '%'; }, 30); }
      });
    }

    // build a card node and play its entrance (fade + rise), then fill bars
    function makeCard(p: Payer, delay = 0): HTMLElement {
      const tmp = document.createElement('div');
      tmp.innerHTML = cardHtml(p).trim();
      const el = tmp.firstElementChild as HTMLElement;
      if (reduceMotion) { fillBars(el); return el; }
      el.style.opacity = '0';
      el.style.transform = 'translateY(10px) scale(0.985)';
      setTimeout(() => {
        el.style.opacity = '';
        el.style.transform = '';
        fillBars(el);
      }, delay + 30);
      return el;
    }

    // play exit (fade + drop), then detach
    function removeCard(el: HTMLElement) {
      el.removeAttribute('data-id'); // free the id so it can be re-added immediately
      if (reduceMotion) { el.remove(); return; }
      el.style.pointerEvents = 'none';
      el.style.opacity = '0';
      el.style.transform = 'translateY(10px) scale(0.985)';
      let done = false;
      const finish = () => { if (done) return; done = true; el.remove(); };
      el.addEventListener('transitionend', finish, { once: true });
      setTimeout(finish, 500);
    }

    // empty-state / clear-all / quick-add chrome (driven by logical state, not the DOM)
    function syncChrome() {
      const n = selected.length;
      // the trailing ghost slot stays visible until the comparison is full, so it always
      // shows where the next payer will land.
      emptyAnchor.classList.toggle('hidden', n >= MAX);
      clearBtn.classList.toggle('hidden', n === 0);
      clearBtn.classList.toggle('inline-flex', n > 0);
      capNote.classList.toggle('hidden', n < MAX);
      if (n >= MAX && !capNote.classList.contains('text-rose-600')) capNote.textContent = `(max ${MAX})`;
      document.querySelectorAll<HTMLButtonElement>('.sc-quick').forEach((btn) => {
        const on = selected.includes(btn.dataset.add!);
        btn.classList.toggle('sc-on', on);
        const icon = btn.querySelector('.sc-quick-icon');
        if (icon) icon.textContent = on ? '✓' : '+';
      });
      syncBrowse();
    }

    // reconcile the grid against `selected`: remove dropped cards, append new ones
    function render() {
      const present = new Map<string, HTMLElement>();
      Array.from(grid.children).forEach((node) => {
        const el = node as HTMLElement;
        if (el.dataset && el.dataset.id) present.set(el.dataset.id, el);
      });
      present.forEach((el, id) => {
        if (!selected.includes(id)) removeCard(el);
      });
      const toAdd = selected.filter((id) => !present.has(id));
      toAdd.forEach((id, i) => {
        const p = byId.get(id);
        if (p) grid.appendChild(makeCard(p, toAdd.length > 1 ? i * 70 : 0));
      });
      grid.appendChild(emptyAnchor); // keep the "Add a payer" ghost slot trailing the cards
      syncChrome();
    }

    // ---- detail slide-over ----
    const backdrop = document.getElementById('sc-backdrop')!;
    const panel = document.getElementById('sc-panel')!;
    const panelContent = document.getElementById('sc-panel-content')!;

    const STATUS_ICON: Record<string, string> = {
      yes:     '<span class="text-emerald-500 shrink-0 mt-0.5">✓</span>',
      pass:    '<span class="text-emerald-500 shrink-0 mt-0.5">✓</span>',
      no:      '<span class="text-rose-500 shrink-0 mt-0.5">✕</span>',
      fail:    '<span class="text-rose-500 shrink-0 mt-0.5">✕</span>',
      partial: '<span class="text-amber-500 shrink-0 mt-0.5">●</span>',
    };
    const statusIcon = (s: string) => STATUS_ICON[s] || '<span class="text-slate-300 shrink-0 mt-0.5">•</span>';

    const ALERT_STYLE: Record<string, string> = {
      danger:  'bg-rose-50 border-rose-200 text-rose-800',
      warning: 'bg-amber-50 border-amber-200 text-amber-800',
      info:    'bg-sky-50 border-sky-200 text-sky-800',
    };

    function openDetail(id: string) {
      const p = byId.get(id);
      if (!p) return;
      const oc = color(p.overall.color);

      const alerts = p.alerts.map((a) =>
        `<div class="rounded-lg border px-3.5 py-2.5 text-xs leading-relaxed ${ALERT_STYLE[a.severity] || ALERT_STYLE.info}">${escapeHtml(a.text)}</div>`
      ).join('');

      const cats = p.categories.map((c) => {
        const cc = color(c.color);
        const crit = c.criteria.map((cr) =>
          `<li class="flex items-start gap-2 text-xs text-text-secondary leading-relaxed">${statusIcon(cr.status)}<span>${escapeHtml(cr.text)}</span></li>`
        ).join('');
        return `<div class="border border-slate-200 rounded-lg p-4">
          <div class="flex items-center justify-between gap-2 mb-2.5">
            <span class="font-medium text-sm text-text-primary">${escapeHtml(c.name)}</span>
            <span class="inline-flex items-center gap-2">
              ${starsHtml(c.score, c.max, cc.text)}
              <span class="text-sm font-semibold ${cc.text} tabular-nums">${c.score != null ? c.score + '/' + c.max : '—'}</span>
            </span>
          </div>
          ${crit ? `<ul class="space-y-1.5">${crit}</ul>` : ''}
        </div>`;
      }).join('');

      const obs = p.observations.length
        ? `<ul class="space-y-2">${p.observations.map((o) =>
            `<li class="flex items-start gap-2 text-xs leading-relaxed">${statusIcon(o.status)}<span><span class="font-medium text-text-primary">${escapeHtml(o.label)}:</span> <span class="text-text-secondary">${escapeHtml(o.text)}</span></span></li>`
          ).join('')}</ul>`
        : '';

      const v = p.validation;
      const stat = (label: string, n: number | null) =>
        `<div><div class="font-heading text-lg font-bold text-text-primary tabular-nums">${fmt(n)}</div><div class="text-[0.7rem] text-text-muted mt-0.5">${label}</div></div>`;

      const subPlans = p.subPlanLinks.length
        ? `<div class="text-xs text-text-muted">${p.subPlanLinks.length} sub-plan ${p.subPlanLinks.length === 1 ? 'link' : 'links'} in the documentation</div>`
        : '';

      panelContent.innerHTML = `
        <div class="sticky top-0 ${oc.soft} backdrop-blur border-b border-slate-200/70 px-6 py-4 flex items-start justify-between gap-3 z-10">
          <span class="absolute inset-x-0 top-0 h-1 ${oc.dot}"></span>
          <div class="min-w-0">
            <h2 class="font-heading text-lg font-bold text-text-primary leading-tight">${escapeHtml(p.name)}</h2>
            ${p.schema ? `<div class="text-[0.7rem] uppercase tracking-wide text-text-muted mt-0.5">${escapeHtml(p.schema)}</div>` : ''}
          </div>
          <button type="button" id="sc-close" class="shrink-0 w-8 h-8 inline-flex items-center justify-center rounded-full text-slate-400 hover:text-text-primary hover:bg-white/60 transition" aria-label="Close">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3.5 3.5l9 9M12.5 3.5l-9 9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          </button>
        </div>
        <div class="px-6 py-5 space-y-6">
          <!-- overall -->
          <div class="flex items-center gap-4 ${oc.soft} rounded-xl p-4">
            <div class="text-center">
              <div class="font-heading text-4xl font-bold ${oc.text} leading-none">${p.overall.score != null ? p.overall.score : '—'}<span class="text-xl text-slate-300">/${p.overall.max}</span></div>
            </div>
            <div>
              ${p.overall.label ? `<div class="font-semibold text-sm ${oc.text}">${escapeHtml(p.overall.label)}</div>` : ''}
              <div class="mt-1">${starsHtml(p.overall.score, p.overall.max, oc.text)}</div>
              <div class="text-xs text-text-muted mt-1">Overall compliance rating</div>
            </div>
          </div>

          ${alerts ? `<div class="space-y-2">${alerts}</div>` : ''}

          <!-- categories -->
          <div class="space-y-3">${cats || '<div class="text-sm text-text-muted italic">No scorecard published for this payer yet.</div>'}</div>

          ${p.overallAssessment ? `<div>
            <div class="text-xs font-semibold text-text-muted mb-2">Assessment</div>
            <p class="text-sm text-text-secondary leading-relaxed">${escapeHtml(p.overallAssessment)}</p>
          </div>` : ''}

          ${obs ? `<div>
            <div class="text-xs font-semibold text-text-muted mb-2.5">Observations</div>
            ${obs}
          </div>` : ''}

          <!-- data validation -->
          <div>
            <div class="text-xs font-semibold text-text-muted mb-3">Data volume</div>
            <div class="grid grid-cols-2 gap-4">
              ${stat('Providers', v.providers)}
              ${stat('Rates', v.rates)}
              ${stat('Bundled codes', v.bundledCodes)}
              ${stat('Capitation services', v.coveredServicesCapitation)}
            </div>
          </div>

          <!-- links -->
          <div class="border-t border-slate-100 pt-5 space-y-2.5">
            ${subPlans}
            <a href="${p.url}" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-brand-primary hover:underline">
              Full documentation
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M5 3h6v6M11 3L4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            ${p.tocUrl ? `<a href="${p.tocUrl}" target="_blank" rel="noopener" class="flex items-center gap-2 text-sm font-medium text-brand-primary hover:underline">
              Machine-readable files
              <svg width="13" height="13" viewBox="0 0 14 14" fill="none"><path d="M5 3h6v6M11 3L4 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>` : ''}
            ${p.updatedAt ? `<div class="text-[0.7rem] text-text-muted pt-1">Documentation updated ${new Date(p.updatedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</div>` : ''}
          </div>
        </div>`;

      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      panel.classList.remove('translate-x-full');
      panel.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      document.getElementById('sc-close')?.addEventListener('click', closeDetail);
    }

    function closeDetail() {
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      panel.classList.add('translate-x-full');
      panel.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    // ---- search ----
    const searchInput = document.getElementById('sc-search') as HTMLInputElement;
    const results = document.getElementById('sc-results')!;
    const searchWrap = document.getElementById('sc-search-wrap')!;

    function runSearch() {
      const q = searchInput.value.trim().toLowerCase();
      if (!q) { results.classList.add('hidden'); return; }
      const matches = payers
        .filter((p) => p.name.toLowerCase().includes(q) || (p.schema || '').toLowerCase().includes(q))
        .slice(0, 8);
      if (!matches.length) {
        results.innerHTML = '<li class="px-4 py-3 text-sm text-text-muted">No payers match that search.</li>';
        results.classList.remove('hidden');
        return;
      }
      results.innerHTML = matches.map((p) => {
        const on = selected.includes(p.id);
        const oc = color(p.overall.color);
        return `<li>
          <button type="button" data-add="${p.id}" class="sc-result w-full flex items-center gap-3 px-4 py-2.5 text-left hover:bg-slate-50 transition ${on ? 'opacity-50' : ''}">
            <span class="w-2 h-2 rounded-full ${oc.dot} shrink-0"></span>
            <span class="flex-1 text-sm text-text-primary truncate">${escapeHtml(p.name)}</span>
            <span class="text-xs ${on ? 'text-text-muted' : 'text-brand-primary font-medium'}">${on ? 'Added' : '+ Add'}</span>
          </button>
        </li>`;
      }).join('');
      results.classList.remove('hidden');
    }

    function flashCap() {
      capNote.classList.remove('hidden');
      capNote.textContent = `(max ${MAX} — remove one to add another)`;
      capNote.classList.add('text-rose-600');
      setTimeout(() => { capNote.classList.remove('text-rose-600'); render(); }, 1800);
    }

    // ---- events (delegated) ----
    document.addEventListener('click', (e) => {
      const t = (e.target as HTMLElement).closest('[data-add],[data-remove],[data-details]') as HTMLElement | null;
      if (!t) return;
      if (t.dataset.add) {
        // quick-add pills toggle: click again to remove the payer
        if (t.classList.contains('sc-quick') && selected.includes(t.dataset.add)) {
          remove(t.dataset.add);
        } else {
          add(t.dataset.add);
        }
        if (t.classList.contains('sc-result')) { searchInput.value = ''; results.classList.add('hidden'); searchInput.focus(); }
      } else if (t.dataset.remove) {
        remove(t.dataset.remove);
      } else if (t.dataset.details) {
        openDetail(t.dataset.details);
      }
    });

    searchInput.addEventListener('input', runSearch);
    searchInput.addEventListener('focus', runSearch);
    document.addEventListener('click', (e) => {
      if (!searchWrap.contains(e.target as Node)) results.classList.add('hidden');
    });
    document.getElementById('sc-clear')?.addEventListener('click', () => { selected = []; save(); render(); });
    document.getElementById('sc-empty-add')?.addEventListener('click', (e) => {
      e.stopPropagation(); // don't let the global click-out handler immediately close it
      if (!browseOpen) openBrowse('tile');
      else closeBrowse();
    });
    backdrop.addEventListener('click', closeDetail);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') { closeDetail(); closeBrowse(); } });

    // ---- "See all payers" checkbox dropdown ----
    const browseWrap = document.getElementById('sc-browse-wrap')!;
    const browseToggle = document.getElementById('sc-browse-toggle')!;
    const browsePanel = document.getElementById('sc-browse-panel')!;
    const browseChevron = document.getElementById('sc-browse-chevron')!;
    const browseFilter = document.getElementById('sc-browse-filter') as HTMLInputElement;
    const browseList = document.getElementById('sc-browse-list')!;
    const browseCount = document.getElementById('sc-browse-count')!;
    const browseNoResults = document.getElementById('sc-browse-noresults')!;

    // The one picker panel is shared between two triggers: the "See all" pill and the
    // empty-state ghost tile. We relocate it under whichever trigger opened it.
    let browseOpen = false;
    let pickerAnchor: 'see-all' | 'tile' = 'see-all';
    function placePanel(mode: 'see-all' | 'tile') {
      pickerAnchor = mode;
      if (mode === 'tile') {
        // overlay the tile's full footprint, anchored to its top — the tile "becomes" the list
        emptyAnchor.appendChild(browsePanel);
        browsePanel.classList.add('left-0', 'top-0');
        browsePanel.classList.remove('w-80', 'mt-2');
      } else {
        // compact dropdown anchored to the right edge of the "See all" pill
        browseWrap.appendChild(browsePanel);
        browsePanel.classList.remove('left-0', 'top-0');
        browsePanel.classList.add('w-80', 'mt-2');
      }
    }

    // keep checkboxes, cap-disabled states, and the footer count in sync with `selected`
    function syncBrowse() {
      const atCap = selected.length >= MAX;
      browseList.querySelectorAll<HTMLInputElement>('.sc-check').forEach((cb) => {
        const on = selected.includes(cb.dataset.id!);
        cb.checked = on;
        cb.disabled = atCap && !on;
        const row = cb.closest('.sc-browse-row') as HTMLElement | null;
        if (row) row.classList.toggle('opacity-40', atCap && !on);
      });
      browseCount.textContent = `${selected.length} of ${MAX} selected`;
    }

    function openBrowse(mode: 'see-all' | 'tile' = 'see-all') {
      placePanel(mode);
      browseOpen = true;
      browsePanel.classList.remove('hidden');
      browseToggle.setAttribute('aria-expanded', mode === 'see-all' ? 'true' : 'false');
      browseChevron.classList.toggle('rotate-180', mode === 'see-all');
      syncChrome();
      syncBrowse();
      browseFilter.focus();
    }
    function closeBrowse() {
      browseOpen = false;
      browsePanel.classList.add('hidden');
      browseToggle.setAttribute('aria-expanded', 'false');
      browseChevron.classList.remove('rotate-180');
      if (pickerAnchor === 'tile') placePanel('see-all'); // return it to its default home
      syncChrome(); // collapse the empty slot now if a payer was added
    }
    browseToggle.addEventListener('click', (e) => {
      e.stopPropagation();
      if (!browseOpen) openBrowse('see-all');
      else closeBrowse();
    });
    document.getElementById('sc-browse-done')?.addEventListener('click', closeBrowse);
    document.addEventListener('click', (e) => {
      if (!browseOpen) return;
      const t = e.target as Node;
      if (browsePanel.contains(t) || browseWrap.contains(t) || emptyAnchor.contains(t)) return;
      closeBrowse();
    });

    // toggling a checkbox adds/removes that payer (respecting the cap)
    browseList.addEventListener('change', (e) => {
      const cb = (e.target as HTMLElement).closest('.sc-check') as HTMLInputElement | null;
      if (!cb) return;
      const id = cb.dataset.id!;
      if (cb.checked) {
        if (selected.length >= MAX) { cb.checked = false; flashCap(); return; }
        add(id);
        // the tile picker is a "pick one, drop it in" flow: close it so the ghost slot
        // reappears next to the new card. (The "See all" pill stays open for multi-select.)
        if (pickerAnchor === 'tile') closeBrowse();
      } else {
        remove(id);
      }
    });

    // in-panel filter
    browseFilter.addEventListener('input', () => {
      const q = browseFilter.value.trim().toLowerCase();
      let shown = 0;
      browseList.querySelectorAll<HTMLElement>('.sc-browse-row').forEach((row) => {
        const hit = !q || (row.dataset.name || '').includes(q);
        row.classList.toggle('hidden', !hit);
        if (hit) shown++;
      });
      browseNoResults.classList.toggle('hidden', shown > 0);
    });

    // ---- init ----
    load();
    render();
  </script>

  <style is:global>
    /* subtle dot-grid texture for the workspace canvas; fades out toward the bottom */
    .sc-dots {
      background-image: radial-gradient(circle at center, rgba(4, 66, 97, 0.06) 1px, transparent 1.4px);
      background-size: 24px 24px;
      -webkit-mask-image: linear-gradient(to bottom, black, transparent 78%);
      mask-image: linear-gradient(to bottom, black, transparent 78%);
    }

    /* card enter/exit + hover, and the dimension score-bar fill */
    .sc-card {
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
        box-shadow 0.25s ease, border-color 0.25s ease;
      will-change: opacity, transform;
    }
    .sc-bar {
      transition: width 0.8s cubic-bezier(0.22, 1, 0.36, 1);
    }
    /* selected quick-add pill: same blue fill as the hover state
       (!important is needed to win over Tailwind's bg-white / border utilities) */
    .sc-quick.sc-on {
      background-color: var(--color-brand-primary-light) !important;
      border-color: var(--color-brand-primary) !important;
      color: var(--color-brand-primary) !important;
    }
    .sc-quick.sc-on .sc-quick-icon {
      color: var(--color-brand-primary) !important;
    }
    @media (prefers-reduced-motion: reduce) {
      .sc-card,
      .sc-bar {
        transition: none !important;
      }
    }
  </style>
</PageLayout>
