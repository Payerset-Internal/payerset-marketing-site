---
import { topics as topicConfig } from '../../config/transparency-topics';

interface Props {
  tag: string;
  tagType: 'newsletter' | 'brief' | 'research';
  title: string;
  description: string;
  meta: string;
  href: string;
  topics?: string[];
}

const { tag, tagType, title, description, meta, href, topics = [] } = Astro.props;

const topicDetails = topics
  .map(slug => topicConfig.find(t => t.slug === slug))
  .filter(Boolean);

const tagColors: Record<string, string> = {
  newsletter: 'text-brand-dark',
  brief: 'text-brand-accent',
  research: 'text-brand-secondary',
};
---

<a
  class="block bg-white rounded-xl border border-slate-200 p-6 shadow-sm hover:shadow-md hover:border-brand-primary/30 transition-all duration-300 no-underline text-inherit"
  href={href}
>
  <div class="flex items-baseline gap-2.5 flex-wrap mb-3">
    <span class:list={['text-[0.75rem] font-medium', tagColors[tagType] || tagColors.brief]}>
      {tag}
    </span>
    {topicDetails.length > 0 && (
      <span class="text-[0.7rem] text-text-muted">
        {topicDetails.map((t, i) => (
          <>
            {i > 0 && <span class="text-text-muted/40"> · </span>}
            <span>{t!.shortLabel}</span>
          </>
        ))}
      </span>
    )}
  </div>
  <h3 class="font-heading text-base font-medium leading-snug tracking-tight text-text-primary mb-2">
    {title}
  </h3>
  <p class="text-sm text-text-muted leading-relaxed flex-1">
    {description}
  </p>
  <div class="text-xs text-text-muted mt-4 pt-3 border-t border-slate-100 opacity-85">
    {meta}
  </div>
</a>
