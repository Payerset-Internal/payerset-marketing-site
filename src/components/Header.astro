---
import { Image } from 'astro:assets';
import payersetLogo from '../assets/images/payerset-logo-dark.png';

const navItems = [
  {
    label: 'Solutions',
    children: [
      { label: 'Rate Explorer', href: '/rateexplorer' },
      { label: 'Data Lake', href: '/datalake' },
    ],
  },
  {
    label: 'Blog & Podcast',
    children: [
      { label: 'Blog', href: '/insights' },
      { label: 'Payercast', href: '/insights/categories/payercast' },
    ],
  },
  {
    label: 'Resources',
    children: [
      { label: 'Payer Scorecard', href: 'https://docs.payerset.com/payers/aetna-price-transparency', external: true },
      { label: 'Data Dictionaries', href: 'https://docs.payerset.com/rate-explorer/data-dictionary', external: true },
    ],
  },
  { label: 'Research', href: '/research' },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About Us', href: '/about-us' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-slate-200">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-[72px]">
      <!-- Logo -->
      <a href="/" class="flex items-center">
        <Image src={payersetLogo} alt="Payerset" class="h-6 w-auto" />
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden lg:flex items-center gap-1">
        {navItems.map((item) => (
          item.children ? (
            <div class="relative group">
              <button class="px-3 py-2 text-[15px] font-light text-text-primary hover:text-brand-primary rounded-md hover:bg-slate-50 transition-colors flex items-center gap-1">
                {item.label}
                <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
                <div class="bg-white rounded-lg shadow-lg border border-slate-200 py-2 min-w-[200px]">
                  {item.children.map((child) => (
                    <a
                      href={child.href}
                      class="block px-4 py-2 text-[15px] font-light text-text-secondary hover:text-brand-primary hover:bg-slate-50 transition-colors"
                      target={child.external ? '_blank' : undefined}
                      rel={child.external ? 'noopener noreferrer' : undefined}
                    >
                      {child.label}
                      {child.external && (
                        <svg class="w-3 h-3 inline-block ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      )}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 text-[15px] font-light rounded-md transition-colors',
                currentPath === item.href
                  ? 'text-brand-primary bg-slate-50'
                  : 'text-text-primary hover:text-brand-primary hover:bg-slate-50',
              ]}
            >
              {item.label}
            </a>
          )
        ))}
      </div>

      <!-- CTA Buttons -->
      <div class="hidden lg:flex items-center gap-3">
        <a
          href="https://app.payerset.com/login"
          class="text-[15px] font-light text-text-primary hover:text-brand-primary transition-colors"
        >
          Login
        </a>
        <a
          href="/get-started"
          class="inline-flex items-center px-5 py-2.5 text-sm font-semibold text-white bg-brand-dark-deep hover:bg-brand-dark rounded-lg transition-colors"
        >
          Get started
        </a>
      </div>

      <!-- Mobile menu button -->
      <button
        id="mobile-menu-btn"
        class="lg:hidden p-2 text-slate-600 hover:text-brand-dark rounded-md"
        aria-label="Toggle navigation menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden lg:hidden pb-4">
      <div class="space-y-1 pt-2 border-t border-slate-200">
        {navItems.map((item) => (
          item.children ? (
            <div>
              <div class="px-3 py-2 text-sm font-medium text-text-muted uppercase tracking-wider">
                {item.label}
              </div>
              {item.children.map((child) => (
                <a
                  href={child.href}
                  class="block px-6 py-2 text-sm font-light text-text-secondary hover:text-brand-primary hover:bg-slate-50 rounded-md transition-colors"
                  target={child.external ? '_blank' : undefined}
                  rel={child.external ? 'noopener noreferrer' : undefined}
                >
                  {child.label}
                </a>
              ))}
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'block px-3 py-2 text-sm font-light rounded-md transition-colors',
                currentPath === item.href
                  ? 'text-brand-primary bg-slate-50'
                  : 'text-text-primary hover:text-brand-primary hover:bg-slate-50',
              ]}
            >
              {item.label}
            </a>
          )
        ))}
        <div class="pt-3 space-y-2 border-t border-slate-200 mt-3">
          <a href="https://app.payerset.com/login" class="block px-3 py-2 text-sm font-light text-text-primary hover:text-brand-primary transition-colors">
            Login
          </a>
          <a href="/get-started" class="block mx-3 text-center px-4 py-2 text-sm font-semibold text-white bg-brand-dark-deep hover:bg-brand-dark rounded-lg transition-colors">
            Get started
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
