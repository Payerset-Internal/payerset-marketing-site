---
import TPFeaturedCard from './TPFeaturedCard.astro';
import TPFeedCard from './TPFeedCard.astro';

interface FeedItem {
  tag: string;
  tagType: 'podcast' | 'newsletter' | 'brief' | 'research';
  title: string;
  description: string;
  meta: string;
  href: string;
  date: Date;
  topics: string[];
}

interface Episode {
  episode: number;
  title: string;
  description: string;
  duration: string;
  date: Date;
  href: string;
}

interface Props {
  feedItems: FeedItem[];
  scorecard: {
    tag: string;
    title: string;
    description: string;
    href: string;
  };
  latestEpisode?: Episode;
}

const { feedItems, scorecard, latestEpisode } = Astro.props;

const allItems = [...feedItems].sort((a, b) => b.date.getTime() - a.date.getTime());

const tabs = [
  { id: 'all',      label: 'All' },
  { id: 'research', label: 'Research' },
  { id: 'analysis', label: 'Analysis' },
  { id: 'policy',   label: 'Policy' },
  { id: 'playbook', label: 'Field Guides' },
  { id: 'equity',   label: 'Patient Equity' },
  { id: 'employer', label: 'Employers' },
];

function getMatchingTabs(item: FeedItem): string[] {
  const matched = ['all'];
  if (item.tagType === 'brief' || item.tagType === 'research') matched.push('research');
  item.topics.forEach(t => matched.push(t));
  return matched;
}

const episodeDateStr = latestEpisode?.date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

<!-- Latest Episode callout — always visible above tabs -->
{latestEpisode && (
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-6">
    <div class="flex items-center justify-between mb-4">
      <div class="text-xs font-semibold tracking-widest uppercase text-text-muted">The Podcast</div>
      <a href="/transparencyproject/podcast" class="text-xs font-medium text-brand-primary hover:text-brand-primary-hover transition-colors">
        All episodes →
      </a>
    </div>
    <a
      href={latestEpisode.href}
      class="group grid sm:grid-cols-12 bg-white rounded-xl border border-slate-200 overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-0.5 transition-all duration-300 no-underline text-inherit"
    >
      <!-- Left panel -->
      <div class="sm:col-span-3 bg-brand-dark-deep flex flex-col items-center justify-center p-8 relative overflow-hidden min-h-[140px]">
        <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_50%_80%,rgba(100,194,185,0.2)_0%,transparent_70%)]"></div>
        <div class="relative z-10 flex flex-col items-center gap-3">
          <!-- Play button -->
          <div class="w-12 h-12 rounded-full bg-brand-accent flex items-center justify-center group-hover:bg-brand-accent/90 transition-colors shadow-lg">
            <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
              <path d="M6 4.5L14 9L6 13.5V4.5Z" fill="white"/>
            </svg>
          </div>
          <span class="text-xs font-semibold tracking-widest uppercase text-brand-accent/80">
            Ep. {latestEpisode.episode}
          </span>
        </div>
      </div>

      <!-- Right content -->
      <div class="sm:col-span-9 px-7 py-6 flex flex-col justify-center">
        <div class="text-xs font-semibold tracking-wider uppercase text-brand-accent mb-2">Latest Episode</div>
        <h3 class="font-heading text-lg font-semibold text-text-primary leading-snug tracking-tight mb-2">
          {latestEpisode.title}
        </h3>
        <p class="text-sm text-text-muted leading-relaxed mb-4">
          {latestEpisode.description}
        </p>
        <div class="flex items-center gap-4">
          <span class="text-xs text-text-muted">{episodeDateStr} · {latestEpisode.duration}</span>
          <span class="inline-flex items-center gap-2 text-sm font-semibold text-brand-accent">
            <span class="w-6 h-6 rounded-full bg-brand-accent flex items-center justify-center flex-shrink-0">
              <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
                <path d="M3 2L8 5L3 8V2Z" fill="white"/>
              </svg>
            </span>
            Listen now
          </span>
        </div>
      </div>
    </a>
  </div>
)}

<!-- Sticky tab bar, sits below the main header (72px tall) -->
<div id="tp-tab-bar" class="sticky top-[72px] z-40 bg-white border-b border-slate-200 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center gap-1 overflow-x-auto scrollbar-none py-1" role="tablist">
      {tabs.map((tab, i) => (
        <button
          role="tab"
          data-tab={tab.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          class="tp-tab flex-shrink-0 px-4 py-2.5 text-sm font-medium rounded-md transition-all duration-150 whitespace-nowrap"
        >
          {tab.label}
        </button>
      ))}
    </div>
  </div>
</div>

<!-- Featured card — only shown in "All" tab -->
<div id="tp-featured" class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-10 pb-4">
  <div class="text-xs font-semibold tracking-widest uppercase text-text-muted mb-5">Featured</div>
  <TPFeaturedCard
    tag={scorecard.tag}
    title={scorecard.title}
    description={scorecard.description}
    href={scorecard.href}
  />
</div>

<!-- Content grid -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pb-16">
  <div id="tp-feed-grid" class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
    {allItems.map(item => (
      <div
        class="tp-card-wrapper"
        data-tabs={getMatchingTabs(item).join(',')}
      >
        <TPFeedCard
          tag={item.tag}
          tagType={item.tagType}
          title={item.title}
          description={item.description}
          meta={item.meta}
          href={item.href}
          topics={item.topics}
        />
      </div>
    ))}
  </div>
  <div id="tp-empty" class="hidden text-center py-12 text-text-muted text-sm">
    No content in this topic yet. Check back soon.
  </div>
</section>

<script>
  const featured = document.getElementById('tp-featured');
  const feedGrid = document.getElementById('tp-feed-grid');
  const empty = document.getElementById('tp-empty');
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('[data-tab]');
  const cards = feedGrid?.querySelectorAll<HTMLElement>('.tp-card-wrapper');

  function setTab(tabId: string) {
    tabBtns?.forEach(btn => {
      btn.setAttribute('aria-selected', btn.dataset.tab === tabId ? 'true' : 'false');
    });

    if (featured) {
      featured.style.display = tabId === 'all' ? '' : 'none';
    }

    let visibleCount = 0;
    cards?.forEach(card => {
      const tabs = card.dataset.tabs?.split(',') ?? [];
      const show = tabs.includes(tabId);
      card.style.display = show ? '' : 'none';
      if (show) visibleCount++;
    });

    if (empty) {
      empty.classList.toggle('hidden', visibleCount > 0);
    }
  }

  tabBtns?.forEach(btn => {
    btn.addEventListener('click', () => {
      setTab(btn.dataset.tab ?? 'all');
    });
  });
</script>

<style>
  .scrollbar-none {
    scrollbar-width: none;
  }
  .scrollbar-none::-webkit-scrollbar {
    display: none;
  }

  .tp-tab {
    color: var(--color-text-muted);
  }
  .tp-tab:hover {
    color: var(--color-text-primary);
    background-color: var(--color-slate-50);
  }
  .tp-tab[aria-selected="true"] {
    color: var(--color-brand-primary);
    background-color: var(--color-brand-primary-light);
  }
</style>
