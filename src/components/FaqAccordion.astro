---
import type { FaqItem } from '../utils/faq';

interface Props {
  faqs: FaqItem[];
  /** Add staggered scroll-reveal (matches the per-item data-reveal used on product pages). */
  reveal?: boolean;
}

const { faqs, reveal = false } = Astro.props;
---

<div class="space-y-4">
  {faqs.map((faq, i) => (
    <details
      class="group relative bg-white/80 backdrop-blur-sm rounded-xl border border-slate-200/60 overflow-hidden hover:border-brand-primary/15 transition-all duration-200"
      {...(reveal ? { 'data-reveal': true, 'data-reveal-delay': String(i * 80) } : {})}
    >
      <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gradient-to-b from-brand-secondary to-brand-primary opacity-0 group-open:opacity-100 transition-opacity duration-300"></div>
      <summary class="flex items-center justify-between cursor-pointer p-6 text-left font-semibold text-brand-dark hover:bg-brand-primary/[0.03] transition-colors">
        <span set:html={faq.q} />
        <svg class="w-5 h-5 text-brand-primary/50 group-open:text-brand-primary shrink-0 ml-4 transition-all duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-6 pb-6 text-sm text-slate-600 leading-relaxed" set:html={faq.a} />
    </details>
  ))}
</div>
