---
import TPEmailCapture from './TPEmailCapture.astro';

interface Props {
  /** Optional small kicker above the title (e.g. "2026 Edition"). */
  eyebrow?: string;
  /** Hero headline — currently the flagship report's name. */
  title: string;
  /** Pitch paragraph below the title. */
  description: string;
  /** Helper text under the email capture. */
  emailNote?: string;
}

const {
  eyebrow,
  title,
  description,
  emailNote = "Enter your email to receive the report. You'll also be signed up for our bi-weekly newsletter.",
} = Astro.props;
---

<section class="relative bg-brand-dark-deep overflow-hidden">
  <!-- Decorative gradients -->
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-brand-dark-deep"></div>
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12 lg:py-14" data-reveal>
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
      <!-- Left (mobile: below cover): text + email capture -->
      <div class="lg:col-span-7 order-2 lg:order-1">
        {eyebrow && (
          <div class="text-[0.8rem] font-medium text-brand-accent mb-4">
            {eyebrow}
          </div>
        )}
        <h1 class="font-heading text-2xl sm:text-3xl lg:text-4xl font-bold text-white leading-[1.15] tracking-tight mb-4">
          {title}
        </h1>
        <p class="text-sm sm:text-base text-slate-300 leading-relaxed mb-6 max-w-xl">
          {description}
        </p>
        <TPEmailCapture note={emailNote} />
      </div>

      <!-- Right (mobile: above text): placeholder report cover -->
      <div class="lg:col-span-5 order-1 lg:order-2 flex justify-center lg:justify-end">
        <!--
          TODO: Replace this typographic placeholder with the final report
          cover image when artwork is available. Aspect ratio is 3:4 — swap
          for an <img /> at the same proportions to preserve layout.
        -->
        <div class="relative w-full max-w-[220px] sm:max-w-[240px] lg:max-w-[260px] aspect-[3/4] bg-brand-dark-deep border border-white/10 rounded-md shadow-2xl shadow-black/50 flex flex-col justify-between p-5 sm:p-6">
          <!-- Subtle inner gradient for depth -->
          <div class="absolute inset-0 bg-gradient-to-br from-white/[0.02] to-transparent rounded-md pointer-events-none"></div>

          <div class="relative">
            <div class="text-[0.6rem] sm:text-[0.65rem] font-semibold tracking-[0.2em] uppercase text-brand-accent/85 mb-2">
              Vol. 01 · 2026 Edition
            </div>
            <div class="h-px bg-brand-accent/40 w-12"></div>
          </div>

          <div class="relative">
            <div class="font-heading text-3xl sm:text-4xl font-bold text-white leading-none tracking-tight">Rate</div>
            <div class="font-heading text-3xl sm:text-4xl font-light text-brand-accent italic leading-none tracking-tight mt-1">Review</div>
            <div class="h-px bg-white/15 w-full my-4"></div>
            <div class="text-[0.75rem] sm:text-sm font-medium text-slate-300 leading-snug">
              The 2026 Price Transparency Report
            </div>
          </div>

          <div class="relative text-[0.55rem] font-semibold tracking-[0.25em] uppercase text-white/40">
            Payerset
          </div>
        </div>
      </div>
    </div>

    <!-- Scroll cue: signals there's more content below the hero.
         Mobile/tablet only — on lg+ the sticky tab bar peeks above the fold
         and does the job, so this would be redundant. -->
    <a
      href="#tp-tab-bar"
      class="group relative flex lg:hidden justify-center mt-10 no-underline"
    >
      <span class="inline-flex items-center gap-2 text-xs sm:text-sm text-slate-400 group-hover:text-white transition-colors">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true" class="text-brand-accent transition-transform group-hover:translate-y-0.5">
          <path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        Explore analysis, research, and field guides
      </span>
    </a>
  </div>
</section>
