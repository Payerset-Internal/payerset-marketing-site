<div class="hero-map__visual" id="heroMapVisual">
  <div class="hero-map__map-container">
    <!-- US Map SVG -->
    <svg class="hero-map__svg" viewBox="0 0 960 600" preserveAspectRatio="xMidYMid meet" aria-hidden="true">
      <defs>
        <radialGradient id="hmGlow" cx="50%" cy="50%" r="55%">
          <stop offset="0%" stop-color="var(--color-brand-secondary)" stop-opacity="0.07" />
          <stop offset="100%" stop-color="var(--color-brand-secondary)" stop-opacity="0" />
        </radialGradient>
        <linearGradient id="hmMapFill" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stop-color="var(--color-brand-secondary)" stop-opacity="0.03" />
          <stop offset="100%" stop-color="var(--color-brand-primary)" stop-opacity="0.06" />
        </linearGradient>
        <filter id="hmDotGlow">
          <feGaussianBlur stdDeviation="4" result="b" />
          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <filter id="hmDotGlowLg">
          <feGaussianBlur stdDeviation="8" result="b" />
          <feMerge><feMergeNode in="b" /><feMergeNode in="SourceGraphic" /></feMerge>
        </filter>
        <!-- Subtle dot grid pattern -->
        <pattern id="hmGrid" width="24" height="24" patternUnits="userSpaceOnUse">
          <circle cx="12" cy="12" r="0.5" fill="var(--color-brand-secondary)" opacity="0.15" />
        </pattern>
      </defs>

      <!-- Background ambiance -->
      <ellipse cx="480" cy="300" rx="440" ry="280" fill="url(#hmGlow)" />

