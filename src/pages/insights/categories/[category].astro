---
import PageLayout from '../../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const categoryMap: Record<string, string> = {
  'industry-insights': 'Industry Insights',
  'parsing-payer-mrfs': 'Parsing Payer MRFs',
  'payercast': 'Payercast',
  'news': 'News',
};

export async function getStaticPaths() {
  return [
    { params: { category: 'industry-insights' } },
    { params: { category: 'parsing-payer-mrfs' } },
    { params: { category: 'payercast' } },
    { params: { category: 'news' } },
  ];
}

const { category } = Astro.params;
const categoryName = categoryMap[category!] || category;

const posts = await getCollection('blog', ({ data }) => data.category === categoryName);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allCategories = ['All', 'Industry Insights', 'Parsing Payer MRFs', 'Payercast', 'News'];
---

<PageLayout
  title={`${categoryName} - Insights`}
  description={`Healthcare price transparency ${categoryName.toLowerCase()} from the Payerset team.`}
>
  <!-- Hero Section -->
  <section class="relative bg-brand-dark-deep overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-brand-dark-deep"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="max-w-3xl mx-auto text-center">
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-white leading-tight">
          {categoryName}
        </h1>
        <p class="mt-6 text-lg sm:text-xl text-slate-300 max-w-2xl mx-auto">
          Healthcare price transparency {categoryName.toLowerCase()} from the Payerset team.
        </p>
      </div>
    </div>
  </section>

  <!-- Category Filters -->
  <section class="bg-white border-b border-slate-200 sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-2 py-4 overflow-x-auto">
        {allCategories.map((cat) => {
          const slug = cat === 'All' ? '/insights' : `/insights/categories/${cat.toLowerCase().replace(/ /g, '-')}`;
          const isActive = cat === categoryName;
          return (
            <a
              href={slug}
              class:list={[
                'whitespace-nowrap px-5 py-2 text-sm font-semibold rounded-lg transition-colors',
                isActive
                  ? 'bg-brand-primary text-white'
                  : 'bg-slate-100 text-slate-600 hover:bg-slate-200',
              ]}
            >
              {cat}
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Blog Posts Grid -->
  <section class="py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {sortedPosts.length > 0 ? (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {sortedPosts.map((post) => (
            <a
              href={`/post/${post.id.replace(/\.md$/, '')}`}
              class="group bg-white rounded-xl border border-slate-200 overflow-hidden hover:shadow-lg hover:border-brand-primary/30 transition-all duration-200"
            >
              <div class="aspect-video bg-slate-100 flex items-center justify-center">
                {post.data.image ? (
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                  />
                ) : (
                  <div class="text-slate-400 text-sm">
                    <svg class="w-12 h-12 mx-auto mb-2 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
                    </svg>
                  </div>
                )}
              </div>
              <div class="p-6">
                <div class="flex items-center gap-3 mb-3">
                  <span class="inline-block px-3 py-1 text-xs font-semibold text-brand-primary bg-brand-primary/10 rounded-full">
                    {post.data.category}
                  </span>
                  {post.data.readTime && (
                    <span class="text-xs text-slate-400">{post.data.readTime}</span>
                  )}
                </div>
                <h3 class="text-lg font-semibold text-slate-900 group-hover:text-brand-primary transition-colors mb-2">
                  {post.data.title}
                </h3>
                <p class="text-sm text-slate-600 leading-relaxed line-clamp-2">
                  {post.data.description}
                </p>
                <div class="mt-4 flex items-center justify-between">
                  <span class="text-xs text-slate-400">
                    {post.data.date.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </span>
                  <span class="text-xs text-slate-400">{post.data.author}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="text-center py-12">
          <p class="text-slate-500">No posts in this category yet.</p>
          <a href="/insights" class="mt-4 inline-block text-brand-primary hover:text-brand-primary-hover font-semibold">
            View all posts
          </a>
        </div>
      )}
    </div>
  </section>
</PageLayout>
