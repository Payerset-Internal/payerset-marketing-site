---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Pricing — Payerset | Healthcare Price Transparency for Hospitals & Health Systems"
  description="Price transparency and claims data built for hospital finance teams. One platform, every contracted rate in your market."
>

  <!-- ── HERO ── -->
  <section class="relative bg-brand-dark-deep overflow-hidden text-center px-6 pt-20 pb-16">
    <div class="absolute top-[-200px] right-[-100px] w-[700px] h-[700px] rounded-full bg-[radial-gradient(circle,rgba(0,146,202,0.15)_0%,transparent_65%)] pointer-events-none"></div>
    <div class="absolute bottom-[-150px] left-[-80px] w-[500px] h-[500px] rounded-full bg-[radial-gradient(circle,rgba(0,146,202,0.06)_0%,transparent_65%)] pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto">
      <h1 class="text-4xl sm:text-5xl font-semibold text-white leading-tight tracking-tight mb-3">
        Price Transparency Deserves<br />
        <span class="text-brand-primary">Transparent Pricing.</span>
      </h1>
      <p class="text-lg text-white/60 max-w-xl mx-auto leading-relaxed">
        Price transparency and claims data built for hospital finance teams. One platform, every contracted rate in your market.
      </p>
    </div>
  </section>

  <!-- ── NOT A HEALTH SYSTEM LINK ── -->
  <div class="flex justify-center py-8">
    <a href="#other-organizations" class="group inline-flex items-center gap-3 bg-slate-50 border border-slate-200 rounded-full pl-5 pr-4 py-3 hover:border-brand-primary/40 hover:bg-brand-primary/5 transition-all duration-200">
      <span class="text-sm text-slate-600">
        <strong class="font-semibold text-slate-800">Not a health system?</strong> We work with consulting firms, med device, and health tech.
      </span>
      <span class="inline-flex items-center gap-1 text-sm font-semibold text-brand-primary whitespace-nowrap shrink-0">
        Learn more
        <svg class="w-4 h-4 transition-transform group-hover:translate-y-0.5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </span>
    </a>
  </div>

  <!-- ── PRICING TABLE ── -->
  <section class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="max-w-3xl mx-auto bg-white border border-slate-200 rounded-xl overflow-hidden shadow-sm">
      <!-- Header row -->
      <div class="hidden sm:grid grid-cols-[1fr_auto_auto] items-center gap-4 px-8 py-4 bg-slate-50 border-b border-slate-200">
        <span class="text-[11px] font-bold uppercase tracking-[1.5px] text-slate-400">Organization Size</span>
        <span class="text-[11px] font-bold uppercase tracking-[1.5px] text-slate-400 text-right w-32">Starting At</span>
        <span class="w-32"></span>
      </div>

      {[
        { tier: 'Tier 1', beds: 'Up to 300 Beds', desc: 'Single-facility hospitals', price: '75', label: 'K/yr', cta: 'Get Started', ctaStyle: 'bg-brand-primary hover:bg-brand-primary-hover text-white shadow-[0_2px_8px_rgba(0,146,202,0.3)]' },
        { tier: 'Tier 2', beds: '300 – 1,000 Beds', desc: 'Multi-facility organizations', price: '150', label: 'K/yr', cta: 'Get Started', ctaStyle: 'bg-brand-primary hover:bg-brand-primary-hover text-white shadow-[0_2px_8px_rgba(0,146,202,0.3)]' },
        { tier: 'Tier 3', beds: '1,000 – 5,000 Beds', desc: 'Regional health systems', price: '280', label: 'K/yr', cta: 'Get Started', ctaStyle: 'bg-brand-primary hover:bg-brand-primary-hover text-white shadow-[0_2px_8px_rgba(0,146,202,0.3)]' },
        { tier: 'Tier 4', beds: '5,000+ Beds', desc: 'Large national health systems', price: null, label: 'Custom', cta: 'Talk to Sales', ctaStyle: 'bg-brand-dark hover:bg-brand-dark-deeper text-white shadow-[0_2px_8px_rgba(0,31,41,0.2)]' },
      ].map(({ tier, beds, desc, price, label, cta, ctaStyle }, i) => (
        <div class:list={[
          "sm:grid grid-cols-[1fr_auto_auto] items-center gap-4 px-8 py-5 transition-colors hover:bg-slate-50/80",
          i < 3 ? "border-b border-slate-100" : "",
        ]}>
          <div class="mb-3 sm:mb-0">
            <p class="text-[10px] font-bold uppercase tracking-[2px] text-slate-400 mb-0.5">{tier}</p>
            <p class="text-lg font-bold text-slate-900 leading-tight">{beds}</p>
            <p class="text-xs text-slate-500">{desc}</p>
          </div>
          <div class="flex items-baseline font-heading w-32 justify-end mb-3 sm:mb-0">
            {price ? (
              <>
                <span class="text-sm font-semibold text-slate-900 self-start pt-1">$</span>
                <span class="text-4xl font-extrabold text-slate-900 leading-none tracking-tight">{price}</span>
                <span class="text-sm font-medium text-slate-500 ml-0.5">{label}</span>
              </>
            ) : (
              <span class="text-xl font-bold text-slate-900">{label}</span>
            )}
          </div>
          <a href="/get-started" class:list={["block w-32 text-center px-4 py-3 rounded-lg text-sm font-semibold transition-colors", ctaStyle]}>
            {cta}
          </a>
        </div>
      ))}
    </div>
    <p class="text-center text-xs text-slate-400 mt-4">All prices billed annually. Every tier includes the full Payerset platform.</p>
  </section>

  <!-- ── EVERY PLAN INCLUDES ── -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="text-center mb-10">
      <h2 class="text-3xl font-semibold text-slate-900 tracking-tight mb-3">Every Plan Includes</h2>
      <p class="text-base text-slate-500 max-w-lg mx-auto">No matter which tier you choose, you get the full Payerset data platform — the same data, the same tools, the same support.</p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {[
        {
          title: 'Every Payer MRF',
          desc: '100% of published machine-readable files ingested, enriched, and standardized. No subsets, no cherry-picking.',
          icon: `<path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
        },
        {
          title: 'Claims & Remits',
          desc: 'See what was actually paid — not just contracted. Real-world claims linked to negotiated rates surface the full picture.',
          icon: `<path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
        },
        {
          title: 'Historical Trending',
          desc: 'Full historical data for every payer, hospital, and claims dataset. Track reimbursement movement over time.',
          icon: `<path d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/>`,
        },
        {
          title: 'Onboarding & Support',
          desc: 'We work hand-in-hand with your team from day one — answering questions, helping you understand the data, and making sure you get value fast.',
          icon: `<path d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>`,
        },
        {
          title: 'Quarterly Refreshes',
          desc: 'Full dataset audit and refresh every quarter. Always current with the latest payer structures and CMS requirements.',
          icon: `<path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>`,
        },
        {
          title: 'Enrichment & QA',
          desc: 'NPI-to-TIN mapping, HCO affiliations, standardized schemas. Analysis-ready data from day one.',
          icon: `<path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
        },
      ].map(({ title, desc, icon }) => (
        <div class="bg-white border border-slate-200 rounded-xl p-6 hover:border-brand-primary hover:shadow-[0_4px_12px_rgba(0,146,202,0.08)] transition-all">
          <div class="w-10 h-10 rounded-xl bg-brand-primary/10 flex items-center justify-center text-brand-primary mb-4">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" set:html={icon} />
          </div>
          <h4 class="text-sm font-bold text-slate-900 mb-1.5">{title}</h4>
          <p class="text-sm text-slate-500 leading-relaxed">{desc}</p>
        </div>
      ))}
    </div>
    <div class="mt-8 flex items-center justify-center gap-3 px-8 py-5 bg-slate-50 border border-slate-200 rounded-xl">
      <svg class="w-5 h-5 text-brand-primary shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
        <circle cx="12" cy="12" r="10"/><path d="M12 8v4m0 4h.01"/>
      </svg>
      <p class="text-sm text-slate-600">
        <strong class="font-semibold text-slate-800">The only difference between tiers is bed count.</strong>
        {' '}Need additional seats, Data Lake™ API access, or expanded coverage?{' '}
        <a href="/get-started" class="text-brand-primary font-semibold hover:underline">Let's build the right package →</a>
      </p>
    </div>
  </section>

  <!-- ── OTHER PERSONAS ── -->
  <section id="other-organizations" class="bg-gradient-to-b from-slate-50 to-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-semibold text-slate-900 tracking-tight mb-3">Not a Hospital or Health System?</h2>
        <p class="text-base text-slate-500 max-w-md mx-auto">We partner with teams across the healthcare ecosystem. Let's discuss what you need.</p>
      </div>
      <div class="grid sm:grid-cols-3 gap-5">
        {[
          {
            pill: 'Consulting',
            pillClass: 'bg-purple-100 text-purple-700',
            title: 'Healthcare Consulting',
            desc: 'Arm your engagement teams with the most comprehensive price transparency and claims data on the market. Power client deliverables with real reimbursement intelligence.',
          },
          {
            pill: 'Med Device',
            pillClass: 'bg-emerald-100 text-emerald-700',
            title: 'Medical Device',
            desc: 'Map the reimbursement landscape for your products across payers and geographies. Support value-based pricing and market access strategy with real rate data.',
          },
          {
            pill: 'Health Tech',
            pillClass: 'bg-blue-100 text-blue-700',
            title: 'Health Tech',
            desc: 'Integrate price transparency data directly into your platform via the Payerset Data Lake™. Build pricing tools, cost estimators, and analytics features at scale.',
          },
        ].map(({ pill, pillClass, title, desc }) => (
          <div class="bg-white border border-slate-200 rounded-xl p-8 flex flex-col transition-all duration-300 hover:-translate-y-1 hover:shadow-lg hover:border-slate-300">
            <span class:list={["inline-block self-start px-3 py-1 rounded-md text-[11px] font-bold uppercase tracking-[1px] mb-4", pillClass]}>{pill}</span>
            <h3 class="text-lg font-bold text-slate-900 mb-2 tracking-tight">{title}</h3>
            <p class="text-sm text-slate-500 leading-relaxed flex-1 mb-6">{desc}</p>
            <a href="/get-started" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-primary hover:text-brand-primary-hover transition-colors group">
              Contact for pricing
              <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="relative py-20 lg:py-28 bg-white">
    <div class="absolute top-0 inset-x-0 h-px bg-gradient-to-r from-transparent via-brand-secondary/20 to-transparent"></div>
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-xs font-semibold uppercase tracking-[2.5px] text-brand-primary mb-4">Common Questions</p>
        <h2 class="text-3xl sm:text-4xl font-semibold text-brand-dark">Frequently Asked Questions</h2>
      </div>
      <div class="space-y-4">
        {[
          {
            q: 'What data is included in every plan?',
            a: 'Every plan includes payer price transparency data (all published MRFs), all-payer claims and remits, full historical rate data, and quarterly refreshes. The difference between tiers is based on your organization\'s bed count.',
          },
          {
            q: 'How do you determine which tier I fall into?',
            a: 'Tiers are based on the number of licensed beds at your facility or across your system. Tier 1 covers facilities with up to 300 beds, Tier 2 covers 300–1,000 beds, Tier 3 covers 1,000–5,000 beds, and Tier 4 is for systems with over 5,000 beds. Not sure where you fall? Our team can help you determine the best fit.',
          },
          {
            q: 'Can I add more user seats to my plan?',
            a: 'Yes. All plans support add-on user seats beyond the base allocation. Reach out and we\'ll build the right package for your team.',
          },
          {
            q: 'What is the Payerset Data Lake™?',
            a: 'The Data Lake is our enterprise-grade API and data integration product. It allows you to pipe price transparency and claims data directly into your own analytics, BI tools, or applications. It\'s available as an add-on to any tier.',
          },
          {
            q: "I'm not a hospital. Can I still use Payerset?",
            a: 'Absolutely. We work with healthcare consulting firms, medical device companies, health tech platforms, health plans, and more. Our bed-based pricing tiers are specifically designed for hospitals and health systems, but we build custom packages for other organizations. Reach out and we\'ll scope something for your needs.',
          },
          {
            q: 'How often is the data refreshed?',
            a: 'Data is refreshed quarterly. Every three months we ingest, audit, and enrich the latest payer MRFs, hospital transparency files, and claims data. Full historical data is always retained and accessible for trending.',
          },
        ].map((faq) => (
          <details class="group relative bg-white/80 backdrop-blur-sm rounded-xl border border-slate-200/60 overflow-hidden hover:border-brand-primary/15 transition-all duration-200">
            <div class="absolute left-0 top-0 bottom-0 w-0.5 bg-gradient-to-b from-brand-secondary to-brand-primary opacity-0 group-open:opacity-100 transition-opacity duration-300"></div>
            <summary class="flex items-center justify-between cursor-pointer p-6 text-left font-semibold text-brand-dark hover:bg-brand-primary/[0.03] transition-colors">
              <span>{faq.q}</span>
              <svg class="w-5 h-5 text-brand-primary/50 group-open:text-brand-primary shrink-0 ml-4 transition-all duration-200 group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-6 text-sm text-slate-600 leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="relative bg-brand-dark-deep py-20 px-6 text-center overflow-hidden">
    <div class="absolute top-[-100px] right-[-50px] w-[400px] h-[400px] rounded-full bg-[radial-gradient(circle,rgba(0,146,202,0.12)_0%,transparent_60%)] pointer-events-none"></div>
    <div class="relative max-w-xl mx-auto">
      <h2 class="text-4xl font-semibold text-white tracking-tight mb-4">See Your Market's Data.</h2>
      <p class="text-lg text-white/55 leading-relaxed mb-10">Get a personalized demo with your market's rates and see how Payerset helps your team make smarter, faster contract decisions.</p>
      <a href="/get-started" class="inline-block bg-brand-primary hover:bg-brand-primary-hover text-white font-semibold text-base px-10 py-4 rounded-lg transition-all shadow-[0_4px_16px_rgba(0,146,202,0.35)] hover:shadow-[0_6px_24px_rgba(0,146,202,0.45)] hover:-translate-y-0.5">
        Request Your Demo
      </a>
    </div>
  </section>

</PageLayout>

