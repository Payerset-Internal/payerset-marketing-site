---
// Featured Snowflake Marketplace listing.
// Shared between the Data Lake and Snowflake Marketplace pages so the copy
// lives in one place. Renders a dark, section-framed callout: tightened copy +
// highlights on the left, a stylized "query-ready table" preview on the right,
// and a deep-link to the Snowflake Marketplace listing.
import { Image } from 'astro:assets';
import snowflakeLogo from '../assets/images/snowflake-logo-dark-bg-v2.png';

interface Props {
  // When true, brand the eyebrow with the Snowflake logo (used on the Data Lake
  // page to set this section apart from the feature blocks above it). The
  // Snowflake Marketplace page leaves this off since its hero already carries
  // the Payerset × Snowflake lockup.
  showSnowflakeBrand?: boolean;
}
const { showSnowflakeBrand = false } = Astro.props;

const listingUrl =
  'https://app.snowflake.com/marketplace/listing/GZTSZUEI47X/payerset-inc-healthcare-price-transparency';

const highlights = [
  'In-network negotiated rates from every commercial payer and plan',
  'CPT, HCPCS, MS-DRG, revenue &amp; non-standard codes',
  'Organizational (Type&nbsp;2) NPIs for every facility',
  'Rate type, billing class &amp; service modifiers',
];

// Illustrative rows for the query-ready table preview.
const rows = [
  { code: '99213', rate: '$128.40', type: 'negotiated' },
  { code: '27447', rate: '$1,842.00', type: 'negotiated' },
  { code: 'J1745', rate: '$89.10', type: 'per diem' },
  { code: '0450', rate: '$612.00', type: 'fee schedule' },
];
---

<section class="relative overflow-hidden bg-brand-dark-deep">
  <div class="absolute inset-0 bg-gradient-to-br from-brand-dark via-brand-dark-deep to-brand-dark-deeper"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(0,146,202,0.12),transparent_70%)]"></div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20" data-reveal>
    <div class="rounded-2xl border border-brand-primary/20 bg-white/[0.03] backdrop-blur-sm p-8 sm:p-12">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
        <!-- Left: copy -->
        <div>
          {showSnowflakeBrand ? (
            <div class="flex items-center gap-3 mb-6">
              <Image src={snowflakeLogo} alt="Snowflake" class="h-6 sm:h-7 w-auto" width={840} height={238} loading="lazy" />
              <span class="text-xs font-semibold uppercase tracking-wider text-brand-secondary border-l border-white/15 pl-3 leading-tight">
                Marketplace<br />listing
              </span>
            </div>
          ) : (
            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-semibold bg-brand-secondary/20 text-brand-secondary border border-brand-secondary/30 uppercase tracking-wider mb-6">
              <svg class="w-3 h-3 shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.196-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.783-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z" />
              </svg>
              <span class="leading-none">Now available on Snowflake Marketplace</span>
            </span>
          )}

          <h2 class="text-2xl sm:text-3xl font-semibold text-white mb-6">
            <span class="block">Healthcare Price</span>
            <span class="block">Transparency — Full&nbsp;Dataset</span>
          </h2>

          <ul class="space-y-2.5 mb-8">
            {highlights.map((item) => (
              <li class="flex items-center gap-3 text-slate-200">
                <svg class="w-5 h-5 shrink-0 text-brand-secondary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm sm:text-base" set:html={item} />
              </li>
            ))}
          </ul>

          <a
            href={listingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 text-base font-semibold text-white bg-brand-primary hover:bg-brand-primary-hover rounded-lg transition-colors"
          >
            View on Snowflake Marketplace
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
          </a>
        </div>

        <!-- Right: query-ready table preview -->
        <div class="lg:pl-2">
          <div class="rounded-xl border border-white/10 bg-brand-dark-deeper/70 overflow-hidden shadow-2xl">
            <!-- window / table bar -->
            <div class="flex items-center gap-1.5 px-4 py-3 border-b border-white/10 bg-white/[0.04]">
              <span class="w-2.5 h-2.5 rounded-full bg-red-400/70"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-amber-400/70"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-green-400/70"></span>
              <span class="ml-3 text-xs font-mono text-slate-400">negotiated_rates</span>
            </div>
            <table class="w-full text-left font-mono text-xs sm:text-sm">
              <thead>
                <tr class="text-slate-400">
                  <th class="px-4 py-2.5 font-medium">code</th>
                  <th class="px-4 py-2.5 font-medium">rate</th>
                  <th class="px-4 py-2.5 font-medium">rate_type</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((r) => (
                  <tr class="border-t border-white/[0.06]">
                    <td class="px-4 py-2.5 text-white">{r.code}</td>
                    <td class="px-4 py-2.5 text-brand-secondary">{r.rate}</td>
                    <td class="px-4 py-2.5 text-slate-300">{r.type}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          <p class="mt-4 text-center text-xs text-slate-400">
            Distilled from <span class="font-semibold text-slate-200">~15 trillion</span> raw MRF records each cycle
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
