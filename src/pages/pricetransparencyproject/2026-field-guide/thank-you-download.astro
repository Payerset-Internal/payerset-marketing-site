---
import PageLayout from '../../../layouts/PageLayout.astro';

/**
 * Thank-you / download page for the 2026 Price Transparency Field Guide.
 *
 * MailChimp's form is configured (in the MailChimp dashboard) to redirect
 * subscribers here after a successful submission. The page is publicly
 * accessible at its URL — it's "soft-gated" by being unlinked from site
 * navigation, which is standard practice for marketing lead magnets.
 *
 * TODO: The PDF at /public/reports/rate-review-2026.pdf is currently a
 *       placeholder ("PLACEHOLDER FILE — Do Not Distribute"). Replace
 *       it with the real published report before launch. URL stays the
 *       same; no code change needed.
 */
const downloadUrl = '/reports/rate-review-2026.pdf';
---

<PageLayout
  title="You're subscribed — 2026 Price Transparency Field Guide | Price Transparency Project"
  description="Thanks for subscribing. Your copy of The 2026 Price Transparency Field Guide will be on its way to your inbox on June 10th."
>
  <!-- Confirmation hero -->
  <section class="relative bg-brand-dark-deep overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-brand-dark to-brand-dark-deep"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-primary/10 rounded-full blur-3xl pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 w-80 h-80 bg-brand-accent/10 rounded-full blur-3xl pointer-events-none"></div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-12 lg:py-14 text-center" data-reveal>
      <!-- Small confirmation marker -->
      <div class="inline-flex items-center justify-center w-12 h-12 rounded-full bg-brand-accent/15 border border-brand-accent/30 mb-6">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M5 12.5l4.5 4.5L19 7.5" stroke="#479F79" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-white leading-[1.15] tracking-tight mb-5">
        Thank you.
      </h1>

      <p class="text-base text-slate-300 leading-relaxed max-w-2xl mx-auto">
        Your copy of <em class="text-white not-italic font-medium">The 2026 Price Transparency Field Guide</em> will be on its way to your inbox on June 10th. You'll also receive our newsletter with the latest analysis, research, and field guides from the Project.
      </p>

      {/* Download CTA temporarily removed until the report publishes on
          June 10th. Restore this block (and use `downloadUrl` above) once the
          real PDF is in place. */}
      {/*
      <div class="flex flex-col items-center mt-12 sm:mt-14">
        <span class="text-xs sm:text-sm text-white/55 mb-3">Or grab it right now:</span>
        <a
          href={downloadUrl}
          download
          class="group inline-flex items-center gap-2.5 px-8 py-4 rounded-lg bg-brand-accent text-brand-dark-deep font-semibold text-base no-underline shadow-lg shadow-black/30 hover:bg-brand-accent/90 transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true" class="transition-transform group-hover:translate-y-0.5">
            <path d="M9 1.5v10M4.5 7L9 11.5 13.5 7M2.5 15.5h13" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Download the report
        </a>
      </div>
      */}
    </div>
  </section>

  <!-- What's next -->
  <section class="bg-white border-t border-slate-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <h2 class="font-heading text-2xl sm:text-3xl font-semibold text-text-primary leading-tight tracking-tight text-center mb-10">
        Explore the Price Transparency Project
      </h2>

      <div class="grid md:grid-cols-3 gap-5">
        <!-- Card 1: Payer Compliance Scorecard -->
        <a
          href="/pricetransparencyproject/scorecard"
          class="group flex flex-col bg-white rounded-xl border border-slate-200 p-6 hover:border-brand-primary/40 hover:shadow-md transition-all duration-200 no-underline text-inherit"
        >
          <div class="text-[0.8rem] font-medium text-brand-primary mb-3">Analysis</div>
          <h3 class="font-heading text-lg font-semibold text-text-primary leading-snug tracking-tight mb-2">
            Payer Compliance Scorecard
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-5 flex-1">
            How well are 100+ payers following the price transparency rules? See who's leading, who's lagging, and where enforcement gaps remain.
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-medium text-brand-primary group-hover:gap-3 transition-all">
            See the scorecard
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <!-- Card 2: Latest research & analysis -->
        <a
          href="/pricetransparencyproject/analysis"
          class="group flex flex-col bg-white rounded-xl border border-slate-200 p-6 hover:border-brand-primary/40 hover:shadow-md transition-all duration-200 no-underline text-inherit"
        >
          <div class="text-[0.8rem] font-medium text-brand-primary mb-3">Research</div>
          <h3 class="font-heading text-lg font-semibold text-text-primary leading-snug tracking-tight mb-2">
            The latest analysis
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-5 flex-1">
            Data-driven looks at pricing patterns, market variation, and what the numbers reveal about payer-provider dynamics.
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-medium text-brand-primary group-hover:gap-3 transition-all">
            Read the latest
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>

        <!-- Card 3: Explore the Project -->
        <a
          href="/pricetransparencyproject"
          class="group flex flex-col bg-white rounded-xl border border-slate-200 p-6 hover:border-brand-primary/40 hover:shadow-md transition-all duration-200 no-underline text-inherit"
        >
          <div class="text-[0.8rem] font-medium text-brand-primary mb-3">Browse</div>
          <h3 class="font-heading text-lg font-semibold text-text-primary leading-snug tracking-tight mb-2">
            Browse all topics
          </h3>
          <p class="text-sm text-text-muted leading-relaxed mb-5 flex-1">
            Newsletters, field guides, policy analysis, patient equity, and more — browse the full content feed by topic.
          </p>
          <span class="inline-flex items-center gap-2 text-sm font-medium text-brand-primary group-hover:gap-3 transition-all">
            See all topics
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2.5 7h9M8 3.5L11.5 7 8 10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>
</PageLayout>
